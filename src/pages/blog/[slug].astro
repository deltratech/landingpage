---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const API_BASE = import.meta.env.PUBLIC_API_URL;
const { slug } = Astro.params;

type Tag = { id: string; name: string };

type Post = {
  id: string;
  title: string;
  slug: string;
  content: string;
  excerpt: string | null;
  coverImage: string | null;
  status: string;
  createdAt: string;
  updatedAt: string;
  tags: Tag[];
};

const TAG_COLORS = [
  'bg-tint text-accent border-border',
  'bg-peach border border-[#e8b8a8] text-[#c05a3a]',
  'bg-lavender border border-[#bbadd8] text-[#7a5aa8]',
];

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', {
    month: 'long', day: 'numeric', year: 'numeric',
  });
}

function estimateReadTime(content: string) {
  const words = content?.split(/\s+/).length ?? 0;
  return `${Math.max(1, Math.ceil(words / 200))} min read`;
}

let post: Post | null = null;

try {
  const res = await fetch(`${API_BASE}/posts/${slug}`);
  if (res.ok) {
    const json = await res.json();
    post = json.data ?? null;
  }
} catch { /* redirect below */ }

if (!post) return Astro.redirect('/blog');

const readTime  = estimateReadTime(post.content);
const date      = formatDate(post.createdAt);
const coverSrc  = post.coverImage
  ?? 'https://images.unsplash.com/photo-1509062522246-3755977927d7?w=1400&h=640&fit=crop&auto=format&q=80';

function contentToHtml(text: string): string {
  return text
    .split(/\n{2,}/)
    .map(p => p.trim())
    .filter(Boolean)
    .map(p => {
      const m = p.match(/^(#{1,3})\s(.+)/);
      if (m) {
        const level = m[1].length + 1;
        return `<h${level} class="article-heading">${m[2]}</h${level}>`;
      }
      return `<p>${p.replace(/\n/g, '<br/>')}</p>`;
    })
    .join('');
}

const contentHtml = contentToHtml(post.content);
---

<Layout title={`${post.title} — Deltra`}>
  <Nav />

  <main class="min-h-screen bg-surface">

    <!-- ── Page header (dark, below fixed nav) ───────────── -->
    <header class="bg-primary pt-24 pb-10">
      <div class="max-w-5xl mx-auto px-6 md:px-12">

        <!-- Back link -->
        <div class="text-white">
          <a
            href="/blog"
            class="inline-flex items-center gap-1.5 font-sans text-lg font-semibold text-white hover:text-accent transition-colors duration-200 mb-6"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
            All articles
          </a>
        </div>

        <!-- Tags -->
        {post.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {post.tags.map((tag, i) => (
              <span class={`inline-flex items-center font-sans font-semibold text-xs border rounded-full px-3 py-1 ${TAG_COLORS[i % TAG_COLORS.length]}`}>
                {tag.name}
              </span>
            ))}
          </div>
        )}

        <!-- Title -->
        <h1 class="font-display font-bold text-3xl md:text-5xl text-white leading-tight mb-5 max-w-3xl">
          {post.title}
        </h1>

        <!-- Meta -->
        <div class="flex items-center gap-3 font-sans text-sm text-white/50">
          <span>{date}</span>
          <span class="w-1 h-1 rounded-full bg-white/20 inline-block" />
          <span class="font-semibold text-accent">{readTime}</span>
        </div>

      </div>
    </header>

    <!-- ── Cover image ────────────────────────────────────── -->
    <div class="max-w-5xl mx-auto px-6 md:px-12 -mt-6">
      <div class="rounded-2xl overflow-hidden shadow-xl" style="height:380px;">
        <img
          src={coverSrc}
          alt={post.title}
          style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
        />
      </div>
    </div>

    <!-- ── Article body ───────────────────────────────────── -->
    <div class="max-w-6xl mx-auto px-6 md:px-12 pt-12 pb-16 grid grid-cols-1 lg:grid-cols-[1fr_260px] gap-12">

      <article>
        {post.excerpt && (
          <p class="font-display text-xl md:text-2xl italic leading-relaxed border-l-4 border-accent pl-6 mb-12 text-primary/80">
            {post.excerpt}
          </p>
        )}
        <div class="article-body" set:html={contentHtml} />
      </article>

      <!-- Sidebar -->
      <aside class="hidden lg:flex flex-col gap-6">
        <div class="bg-white border border-border rounded-2xl p-6 flex flex-col gap-4 sticky top-28">
          <p class="font-sans text-xs font-bold uppercase tracking-widest text-muted">About this article</p>
          <div class="flex flex-col gap-3 font-sans text-sm">
            <div class="flex items-center justify-between">
              <span class="text-muted">Published</span>
              <span class="font-semibold text-primary text-right">{date}</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-muted">Read time</span>
              <span class="font-semibold text-accent">{readTime}</span>
            </div>
          </div>
          {post.tags.length > 0 && (
            <div class="border-t border-border pt-4 flex flex-col gap-2">
              <p class="font-sans text-xs font-bold uppercase tracking-widest text-muted">Topics</p>
              <div class="flex flex-wrap gap-2">
                {post.tags.map((tag, i) => (
                  <span class={`inline-flex items-center font-sans font-semibold text-xs border rounded-full px-3 py-1 ${TAG_COLORS[i % TAG_COLORS.length]}`}>
                    {tag.name}
                  </span>
                ))}
              </div>
            </div>
          )}
         
        </div>
      </aside>

    </div>

    <!-- ── Divider ─────────────────────────────────────────── -->
    <div class="max-w-5xl mx-auto px-6 md:px-12">
      <div class="border-t border-border" />
    </div>

    <!-- ── CTA ────────────────────────────────────────────── -->
    <section class="py-20">
      <div class="max-w-5xl mx-auto px-6 md:px-12">
        <div class="bg-primary rounded-3xl px-8 py-12 md:px-14 flex flex-col md:flex-row md:items-center gap-8">
          <div class="flex-1">
            <span class="inline-flex items-center font-sans font-semibold text-xs text-accent bg-accent/10 border border-accent/20 rounded-full px-4 py-1.5 mb-4">
              Deltra for Schools
            </span>
            <h2 class="font-display font-bold text-2xl md:text-3xl text-white leading-snug mb-2">
              Ready to modernise your school?
            </h2>
            <p class="font-sans text-sm text-white/60 leading-relaxed">
              Join hundreds of Indonesian schools already running on Deltra.
            </p>
          </div>
          <a
            href="/#contact"
            class="shrink-0 inline-flex items-center justify-center font-sans font-bold text-sm text-primary bg-accent px-8 py-3.5 rounded-full hover:bg-[#18b899] hover:-translate-y-0.5 transition-all duration-200 shadow-lg shadow-accent/20"
          >
            Request a Demo →
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .article-body {
    font-family: var(--font-sans);
    color: var(--color-body);
    font-size: 1.0625rem;
    line-height: 1.85;
  }
  .article-body :global(p)              { margin-bottom: 1.5rem; }
  .article-body :global(.article-heading) {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-primary);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .article-body :global(h2.article-heading) { font-size: 1.6rem; }
  .article-body :global(h3.article-heading) { font-size: 1.25rem; }
  .article-body :global(h4.article-heading) { font-size: 1.1rem; }
  .article-body :global(strong)         { color: var(--color-primary); font-weight: 700; }
  .article-body :global(em)             { color: var(--color-muted); font-style: italic; }
  .article-body :global(a)              { color: var(--color-accent); text-decoration: underline; text-underline-offset: 3px; }
  .article-body :global(ul),
  .article-body :global(ol)             { padding-left: 1.5rem; margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .article-body :global(ul)             { list-style: disc; }
  .article-body :global(ol)             { list-style: decimal; }
  .article-body :global(blockquote)     { border-left: 4px solid var(--color-accent); padding-left: 1.25rem; margin: 2rem 0; font-style: italic; color: var(--color-muted); }
  .article-body :global(code)           { font-family: var(--font-mono); font-size: 0.85em; background: var(--color-tint); color: var(--color-accent); border: 1px solid var(--color-border); border-radius: 0.375rem; padding: 0.15em 0.45em; }
  .article-body :global(pre)            { background: var(--color-primary); color: #e2e8f0; border-radius: 1rem; padding: 1.5rem; overflow-x: auto; margin-bottom: 1.5rem; font-family: var(--font-mono); font-size: 0.875rem; line-height: 1.7; }
  .article-body :global(pre code)       { background: transparent; border: none; padding: 0; color: inherit; font-size: inherit; }
  .article-body :global(hr)             { border: none; border-top: 1px solid var(--color-border); margin: 2.5rem 0; }
</style>
