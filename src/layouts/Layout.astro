---
import '../styles/global.css';
import Toast from '../components/Toast.astro';
import Chatbot from '../components/Chatbot.astro';
interface Props { title?: string; }
const { title = 'Deltra — One platform. Every workflow. Intelligently automated.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Deltra brings together administration, learning, communication, and AI-powered intelligence — so your school can focus on what matters most: students." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Inter:wght@400;500;600;700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    <Toast />
    <Chatbot />
  </body>
</html>
