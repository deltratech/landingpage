---
interface Props {
  title?: string;
}
const { title = 'Deltra — School Management Platform' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Deltra brings together administration, learning, communication, and AI-powered intelligence — so your school can focus on what matters most: students." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-primary:  #0f1c2e;
    --color-accent:   #1ecfad;
    --color-surface:  #f4faf8;
    --color-tint:     #e8f5f1;
    --color-border:   #c2d9d3;
    --color-body:     #2d4a44;
    --color-muted:    #6b8f88;
    --color-heading:  #0f1c2e;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Space Mono', monospace;
    background: var(--color-surface);
    color: var(--color-body);
    -webkit-font-smoothing: antialiased;
  }

  h1, h2, h3 {
    font-family: 'Caveat', cursive;
    font-weight: 700;
  }

  img { max-width: 100%; display: block; }
  a { text-decoration: none; color: inherit; }
  button, .btn {
    cursor: pointer;
    font-family: 'Space Mono', monospace;
    border: none;
    outline: none;
  }
</style>
