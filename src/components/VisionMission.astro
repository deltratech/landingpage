---
const missions = [
  'Reduce administrative burden for teachers with AI-powered automation',
  'Improve learning efficiency through centralized, intelligent systems',
  'Support data-driven school decisions with real-time analytics',
  'Enhance collaboration between teachers, students & parents seamlessly',
];
---
<section class="vision-mission" id="about">
  <div class="section-inner">
    <div class="vm-grid">
      <!-- Vision -->
      <div class="vision-col">
        <div class="pill-light">Our Vision</div>
        <blockquote class="vision-quote">
          "To transform education through simple and effective digital solutions"
        </blockquote>
        <div class="vision-img-placeholder">
          <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="28" cy="20" r="12" fill="#2FB5A5" opacity="0.3"/>
            <path d="M4 52c0-13.255 10.745-24 24-24s24 10.745 24 24" fill="#2FB5A5" opacity="0.2"/>
          </svg>
          <p>Vision imagery<br />placeholder</p>
        </div>
      </div>

      <!-- Mission -->
      <div class="mission-col">
        <div class="pill-light">Our Mission</div>
        <ol class="mission-list">
          {missions.map((m, i) => (
            <li class:list={['mission-item', { 'no-border': i === missions.length - 1 }]}>
              <span class="mission-num">0{i + 1}</span>
              <span class="mission-text">{m}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </div>

  <!-- Deco circles -->
  <span class="deco deco-1">○</span>
  <span class="deco deco-2">○</span>
</section>

<style>
  .vision-mission {
    background: #192B5E;
    padding: 64px 32px;
    position: relative;
    overflow: hidden;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .vm-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .pill-light {
    display: inline-flex;
    align-items: center;
    font-size: 12px;
    font-weight: 700;
    color: #c8cee8;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 30px;
    padding: 5px 14px;
    margin-bottom: 16px;
  }

  /* Vision */
  .vision-col {
    display: flex;
    flex-direction: column;
  }

  .vision-quote {
    font-size: clamp(18px, 2.5vw, 22px);
    font-weight: 700;
    color: #fff;
    line-height: 1.4;
    margin-bottom: 20px;
    font-style: normal;
  }

  .vision-img-placeholder {
    width: 100%;
    height: 170px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    color: #8890b0;
    font-size: 13px;
    text-align: center;
    line-height: 1.5;
  }

  /* Mission */
  .mission-col {
    display: flex;
    flex-direction: column;
  }

  .mission-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mission-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding-bottom: 16px;
    margin-bottom: 16px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .mission-item.no-border {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  .mission-num {
    font-size: 22px;
    font-weight: 700;
    color: #2FB5A5;
    flex-shrink: 0;
    width: 34px;
    line-height: 1.3;
  }

  .mission-text {
    font-size: 15px;
    color: #c8cee8;
    line-height: 1.5;
  }

  /* Background deco circles */
  .deco {
    position: absolute;
    pointer-events: none;
    color: rgba(255,255,255,0.05);
    font-size: 120px;
    line-height: 1;
  }
  .deco-1 { top: -30px; right: -30px; }
  .deco-2 { bottom: -30px; left: -40px; font-size: 140px; }

  @media (max-width: 768px) {
    .vm-grid { grid-template-columns: 1fr; }
  }
</style>
