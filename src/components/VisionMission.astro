---
const missions = [
  'Reduce administrative burden for teachers with AI-powered automation',
  'Improve learning efficiency through centralized, intelligent systems',
  'Support data-driven school decisions with real-time analytics',
  'Enhance collaboration between teachers, students & parents seamlessly',
];
---
<section class="bg-primary py-16 px-8 relative overflow-hidden" id="about">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">

      <!-- Vision -->
      <div class="flex flex-col">
        <span class="inline-flex self-start items-center font-mono font-bold text-xs text-[#c8e8e0] bg-white/10 border border-white/20 rounded-full px-4 py-1.5 mb-4">
          Our Vision
        </span>
        <blockquote class="font-caveat font-bold text-[clamp(22px,2.5vw,28px)] text-white leading-snug not-italic mb-5">
          "Creating world-class software accessible to every school empowering Indonesian students to compete globally, and building a trusted technology company people can rely on."
        </blockquote>
        <div class="w-full h-43 bg-white/5 border border-white/10 rounded-2xl flex flex-col items-center justify-center gap-2.5 text-white/35 text-[13px] text-center leading-relaxed">
          <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="28" cy="20" r="12" fill="#1ecfad" opacity="0.3"/>
            <path d="M4 52c0-13.255 10.745-24 24-24s24 10.745 24 24" fill="#1ecfad" opacity="0.2"/>
          </svg>
          <p>Vision imagery<br />placeholder</p>
        </div>
      </div>

      <!-- Mission -->
      <div class="flex flex-col">
        <span class="inline-flex self-start items-center font-mono font-bold text-xs text-[#c8e8e0] bg-white/10 border border-white/20 rounded-full px-4 py-1.5 mb-4">
          Our Mission
        </span>
        <blockquote class="font-caveat font-bold text-[clamp(22px,2.5vw,28px)] text-white leading-snug not-italic mb-5">
          Simplify complexity by empowering Indonesia's education system with smart, accessible technology.
        </blockquote>
        
        <ol class="flex flex-col list-none">
          <li class="items-start py-4 border-b border-white/8">
              <span class="font-mono font-bold text-[22px] text-accent shrink-0  leading-snug">FOR SCHOOLS</span>
              <br />
              <span class="font-mono text-[15px] text-[#c8e8e0] leading-relaxed">Cut administrative load so educators can focus on teaching.</span>
          </li>
          <li class="items-start py-4 border-b border-white/8">
              <span class="font-mono font-bold text-[22px] text-accent shrink-0  leading-snug">FOR TEACHERS</span>
              <br />
              <span class="font-mono text-[15px] text-[#c8e8e0] leading-relaxed">Give every teacher an AI co-pilot for feedback, grading and planning.</span>
          </li>
          <li class="items-start py-4 border-b border-white/8">
              <span class="font-mono font-bold text-[22px] text-accent shrink-0  leading-snug">FOR INDONESIA</span>
              <br />
              <span class="font-mono text-[15px] text-[#c8e8e0] leading-relaxed">Build the digital backbone for a modern K–12 system, at local prices.</span>
          </li>
        </ol>
      </div>

    </div>
  </div>

  <span class="absolute -top-7.5 -right-7.5 text-white/4 text-[120px] leading-none pointer-events-none">○</span>
  <span class="absolute -bottom-7.5 -left-10 text-white/4 text-[140px] leading-none pointer-events-none">○</span>
</section>
