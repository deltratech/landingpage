<!-- Toast container + global toast system -->
<div id="toast-root" class="fixed top-5 right-5 z-[9999] flex flex-col gap-2.5 pointer-events-none"></div>

<style>
  @keyframes toast-in {
    from { opacity: 0; transform: translateX(110%) scale(0.95); }
    to   { opacity: 1; transform: translateX(0)    scale(1); }
  }
  @keyframes toast-out {
    from { opacity: 1; transform: translateX(0)    scale(1); }
    to   { opacity: 0; transform: translateX(110%) scale(0.95); }
  }
  .toast-enter { animation: toast-in  0.35s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
  .toast-exit  { animation: toast-out 0.3s  cubic-bezier(0.55, 0, 1, 0.45)  forwards; }
</style>

<script>
  const root = document.getElementById('toast-root')!;

  const ROCKET_SVG = `<svg width="18" height="18" viewBox="0 0 24 24" stroke-width="1.5" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor"><path d="M16.0614 10.4037L14 17H10L7.93865 10.4037C7.35085 8.52273 7.72417 6.47307 8.93738 4.92015L11.5272 1.6052C11.7674 1.29772 12.2326 1.29772 12.4728 1.6052L15.0626 4.92015C16.2758 6.47307 16.6491 8.52273 16.0614 10.4037Z" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 20C10 22 12 23 12 23C12 23 14 22 14 20" stroke-linecap="round" stroke-linejoin="round"/><path d="M8.5 12.5C5 15 7 19 7 19L10 17" stroke-linecap="round" stroke-linejoin="round"/><path d="M15.9312 12.5C19.4312 15 17.4312 19 17.4312 19L14.4312 17" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 11C10.8954 11 10 10.1046 10 9C10 7.89543 10.8954 7 12 7C13.1046 7 14 7.89543 14 9C14 10.1046 13.1046 11 12 11Z" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

  function showToast(title: string = "Coming Soon!", subtitle: string = "We're working on it. Stay tuned.") {
    const el = document.createElement('div');
    el.className = 'toast-enter pointer-events-auto flex items-center gap-3 bg-white border border-gray-100 rounded-2xl px-4 py-3 shadow-[0_8px_30px_rgba(0,0,0,0.10)] min-w-[260px] max-w-[320px]';
    el.innerHTML = `
      <div class="w-9 h-9 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0">
        ${ROCKET_SVG}
      </div>
      <div class="flex flex-col gap-0.5 flex-1">
        <span class="font-mono font-bold text-sm text-primary">${title}</span>
        <span class="font-mono text-xs text-muted leading-snug">${subtitle}</span>
      </div>
      <button class="close-btn w-6 h-6 rounded-full flex items-center justify-center text-muted hover:text-primary hover:bg-gray-100 transition-colors shrink-0 text-xs cursor-pointer" aria-label="Dismiss">✕</button>
    `;

    root.appendChild(el);

    const dismiss = () => {
      el.classList.remove('toast-enter');
      el.classList.add('toast-exit');
      setTimeout(() => el.remove(), 300);
    };

    const timer = setTimeout(dismiss, 3500);
    el.querySelector('.close-btn')!.addEventListener('click', () => {
      clearTimeout(timer);
      dismiss();
    });
  }

  // Expose globally so any component can call it
  (window as any).showToast = showToast;

  // Event delegation — intercept any [data-toast] click
  document.addEventListener('click', (e) => {
    const target = (e.target as HTMLElement).closest('[data-toast]');
    if (!target) return;
    e.preventDefault();
    showToast();
  });
</script>
