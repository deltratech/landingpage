---
const benefits = [
  { title: 'Save Teacher Time',     desc: 'AI assistance cuts admin hours so teachers can focus entirely on teaching',       bg: 'bg-honey'    },
  { title: 'AI-Powered Insights',   desc: 'Auto-generate progress summaries & learning reports per student',                bg: 'bg-mint'     },
  { title: 'Digital Payments',      desc: 'Integrated school billing & payment collection — no manual follow-ups',          bg: 'bg-lavender' },
  { title: 'Data-Driven Decisions', desc: 'Real-time analytics to help school leaders make smarter choices',                bg: 'bg-sky'      },
];
---
<section class="bg-tint py-10 md:py-16 px-4 md:px-8" id="benefits">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col items-center gap-2.5 text-center mb-10">
      <span class="inline-flex items-center font-sans font-bold text-xs text-primary bg-primary/7 border border-primary/14 rounded-full px-4 py-1.5">
        Why Deltra?
      </span>
      <h2 class="text-primary text-6xl font-caveat">Why Schools Choose Deltra</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4.5">
      {benefits.map(b => (
        <div class={`${b.bg} border border-black/6 rounded-[18px] px-5 py-7 flex flex-col items-center text-center gap-3`}>
          <h3 class="text-xl text-primary">{b.title}</h3>
          <p class="font-sans text-[13px] text-body leading-relaxed">{b.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>
