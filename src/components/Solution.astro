---
import dashboardImg from '../assets/images/one-dashboard.png';

const checkItems = [
  'Unified records. Student profile, grades, attendance and fees — one view, one source of truth.',
  'AI where it counts. Teacher copilots, at-risk flags and question generation, tuned for Indonesian curricula.',
  'Parent-ready by default. WhatsApp and email communication built in — no third-party plug-ins.',
  'School-friendly pricing Per-student annual pricing that scales from small to large institutions.',
];
---
<section class="bg-tint py-10 md:py-16 px-4 md:px-8" id="solution">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">

      <!-- Left: screenshot -->
      <div class="w-full rounded-2xl overflow-hidden shadow-[0_8px_40px_rgba(0,0,0,0.12)] border border-white/60 bg-white">
        <img src={dashboardImg.src} class="w-full h-auto block" alt="Deltra dashboard" />
      </div>

      <!-- Right: text content -->
      <div class="flex flex-col gap-4">
        <span class="inline-flex self-start font-sans font-bold text-xs text-primary bg-primary/7 border border-primary/14 rounded-full px-4 py-1.5">
          The Solution
        </span>
        <h2 class="text-primary leading-tight">
          One Platform.<br />Every School Need.
        </h2>
        <p class="font-sans text-sm text-body leading-relaxed">          
            Deltra is an integrated school operating system combining student records, attendance, grading, reporting, finance and Al teaching support in a single, Indonesian-built platform.
        </p>
        <ul class="flex flex-col gap-2.5 list-none">
          {checkItems.map(item => (
            <li class="flex gap-3 items-start font-sans text-sm text-body leading-relaxed">
              <span class="w-6 h-6 rounded-full bg-tint border border-border text-accent flex items-center justify-center text-xs font-bold shrink-0 mt-0.5" aria-hidden="true">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <div class="text-white">
          <a href="#contact" data-toast class="font-sans font-bold text-sm bg-primary px-7 py-3 rounded-full inline-flex items-center transition-all duration-200 hover:bg-accent hover:-translate-y-0.5 hover:scale-[1.03]">
            See How It Works →
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
