---
const checkItems = [
  'Automate daily admin tasks with smart AI assistance',
  'Generate student learning summaries & progress insights automatically',
  'Centralize all learning materials in one intelligent system',
  'Simplify school payment & billing with integrated digital payments',
];
---
<section class="bg-tint py-16 px-8" id="solution">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

      <!-- Left: screenshot placeholder -->
      <div class="w-full h-75 bg-mint border border-[#a8d5c8] rounded-2xl flex flex-col items-center justify-center gap-3 text-muted text-sm text-center leading-relaxed">
        <svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="8" y="14" width="56" height="44" rx="6" fill="#a8d5c8" opacity="0.5"/>
          <rect x="14" y="20" width="44" height="6" rx="3" fill="#1ecfad" opacity="0.4"/>
          <rect x="14" y="30" width="30" height="4" rx="2" fill="#0f1c2e" opacity="0.25"/>
          <rect x="14" y="38" width="20" height="4" rx="2" fill="#0f1c2e" opacity="0.2"/>
          <rect x="14" y="46" width="35" height="4" rx="2" fill="#0f1c2e" opacity="0.2"/>
        </svg>
        <p>Solution diagram<br />or product screenshot</p>
      </div>

      <!-- Right: text content -->
      <div class="flex flex-col gap-4">
        <span class="inline-flex self-start font-mono font-bold text-xs text-primary bg-primary/7 border border-primary/14 rounded-full px-4 py-1.5">
          The Solution
        </span>
        <h2 class="text-primary leading-tight">
          One Platform.<br />Every School Need.
        </h2>
        <p class="font-mono text-sm text-body leading-relaxed">
          Deltra brings together administration, learning, communication, and AI-powered intelligence — so your school can focus on what matters most: students.
        </p>
        <ul class="flex flex-col gap-2.5 list-none">
          {checkItems.map(item => (
            <li class="flex gap-3 items-start font-mono text-sm text-body leading-relaxed">
              <span class="w-6 h-6 rounded-full bg-tint border border-border text-accent flex items-center justify-center text-xs font-bold shrink-0 mt-0.5" aria-hidden="true">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <a href="#contact" class="self-start font-mono font-bold text-sm text-white bg-primary px-6 py-2.5 rounded-full mt-1 transition-all duration-200 hover:bg-accent hover:-translate-y-0.5">
          See How It Works →
        </a>
      </div>

    </div>
  </div>
</section>
