---
const checkItems = [
  'Automate daily admin tasks with smart AI assistance',
  'Generate student learning summaries & progress insights automatically',
  'Centralize all learning materials in one intelligent system',
  'Simplify school payment & billing with integrated digital payments',
];
---
<section class="solution">
  <div class="section-inner">
    <div class="solution-grid">
      <!-- Left: product screenshot placeholder -->
      <div class="screenshot-placeholder">
        <svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="8" y="14" width="56" height="44" rx="6" fill="#a8d5c8" opacity="0.5"/>
          <rect x="14" y="20" width="44" height="6" rx="3" fill="#1ecfad" opacity="0.4"/>
          <rect x="14" y="30" width="30" height="4" rx="2" fill="#0f1c2e" opacity="0.25"/>
          <rect x="14" y="38" width="20" height="4" rx="2" fill="#0f1c2e" opacity="0.2"/>
          <rect x="14" y="46" width="35" height="4" rx="2" fill="#0f1c2e" opacity="0.2"/>
        </svg>
        <p>Solution diagram<br />or product screenshot</p>
      </div>

      <!-- Right: text content -->
      <div class="solution-text">
        <div class="pill">The Solution</div>
        <h2 class="solution-heading">
          One Platform.<br />Every School Need.
        </h2>
        <p class="solution-desc">
          Deltra brings together administration, learning, communication, and AI-powered intelligence — so your school can focus on what matters most: students.
        </p>
        <ul class="check-list">
          {checkItems.map(item => (
            <li class="check-item">
              <span class="check-icon" aria-hidden="true">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <a href="#contact" class="btn-dark">See How It Works →</a>
      </div>
    </div>
  </div>
</section>

<style>
  .solution {
    background: var(--color-tint);
    padding: 64px 32px;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .solution-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .screenshot-placeholder {
    width: 100%;
    height: 300px;
    background: #d4ede5;
    border: 1.5px solid #a8d5c8;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: var(--color-muted);
    font-size: 14px;
    text-align: center;
    line-height: 1.5;
  }

  .solution-text {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    font-size: 12px;
    font-weight: 700;
    color: var(--color-primary);
    background: rgba(15, 28, 46, 0.07);
    border: 1px solid rgba(15, 28, 46, 0.14);
    border-radius: 30px;
    padding: 5px 14px;
    align-self: flex-start;
  }

  .solution-heading { color: var(--color-heading); line-height: 1.2; }
  .solution-desc { font-size: 14px; color: var(--color-body); line-height: 1.7; }

  .check-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .check-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-size: 14px;
    color: var(--color-body);
    line-height: 1.5;
  }

  .check-icon {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--color-tint);
    color: var(--color-accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
    border: 1px solid var(--color-border);
  }

  .btn-dark {
    align-self: flex-start;
    font-family: 'Space Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    background: var(--color-primary);
    padding: 11px 24px;
    border-radius: 40px;
    display: inline-flex;
    align-items: center;
    margin-top: 4px;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-dark:hover { background: var(--color-accent); transform: translateY(-2px); }

  @media (max-width: 768px) {
    .solution-grid { grid-template-columns: 1fr; }
    .screenshot-placeholder { height: 200px; }
  }
</style>
