---
const aiFeatures = [
  {
    title: 'Student Performance Summaries',
    desc: 'Automatically generated weekly AI reports for every student — highlighting strengths, gaps, and recommended next steps for teachers.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>`,
    size: 'md:col-span-2',
  },
  {
    title: 'AI Lesson Planning',
    desc: 'Generate complete lesson plans and exam questions aligned to the Indonesian national curriculum in seconds.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
    size: '',
  },
  {
    title: 'Attendance Anomaly Detection',
    desc: 'AI flags chronic absenteeism patterns before they become critical, so counselors can intervene early.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18M9 16l2 2 4-4"/></svg>`,
    size: '',
  },
  {
    title: 'Predictive Student Analytics',
    desc: 'Identify at-risk students up to 8 weeks in advance using machine learning models trained on Indonesian school data.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    size: 'md:col-span-2',
  },
  {
    title: 'Smart Announcements',
    desc: 'AI drafts school-wide announcements for you — just describe what you need to say, and Deltra writes it in the right tone.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5"/><path d="M17.586 3.414a2 2 0 112.828 2.828L12 14l-4 1 1-4 8.586-8.586z"/></svg>`,
    size: '',
  },
  {
    title: 'AI Report Generation',
    desc: 'End-of-term and mid-year reports written automatically from grade and attendance data — saving 4+ hours per class.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    size: '',
  },
  {
    title: 'Parent Communication Assistant',
    desc: 'Translate student data into parent-friendly summaries automatically — reducing the time teachers spend on individual parent updates.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    size: 'md:col-span-2',
  },
];
---

<section class="bg-primary py-20 md:py-28 overflow-hidden relative" id="ai">
  <!-- Background grid pattern -->
  <div class="absolute inset-0 opacity-5"
    style="background-image: radial-gradient(circle, #1ecfad 1px, transparent 1px); background-size: 40px 40px;">
  </div>

  <div class="relative max-w-6xl mx-auto px-4 md:px-8">

    <div class="text-center mb-14" data-reveal>
      <span class="inline-flex items-center gap-2 font-sans font-semibold text-xs text-accent bg-accent/10 border border-accent/20 rounded-full px-4 py-1.5 mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse inline-block"></span>
        AI-Powered Features
      </span>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
        AI That Works For Your School — <br class="hidden md:block"/>Not Against Your Teachers
      </h2>
      <p class="font-sans text-white/60 text-lg max-w-2xl mx-auto">
        Deltra`s AI engine is trained on Indonesian school contexts. It doesn't just surface data — it tells you what to do with it.
      </p>
    </div>

    <!-- Bento grid of AI features -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {aiFeatures.map((f, i) => (
        <div
          class={`${f.size} bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 hover:border-accent/30 transition-all duration-300 group`}
          data-reveal
          data-delay={String((i % 4) + 1)}
        >
          <div class="w-10 h-10 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center text-accent mb-4 group-hover:bg-accent/20 transition-colors duration-200">
            <span set:html={f.icon}></span>
          </div>
          <h3 class="font-display font-bold text-lg text-white mb-2">{f.title}</h3>
          <p class="font-sans text-white/55 text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-12" data-reveal>
      <a href="#contact" class="font-sans font-bold text-sm text-primary bg-accent px-8 py-3.5 rounded-full inline-flex items-center gap-2 transition-all duration-200 hover:bg-[#18b899] hover:-translate-y-1 hover:shadow-xl hover:shadow-accent/30">
        See AI Features in Action
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>

  </div>
</section>
