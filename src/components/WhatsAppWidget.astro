---
const WHATSAPP_NUMBER = '6281234567890';
const MESSAGE = encodeURIComponent('Halo, saya ingin mengetahui lebih lanjut tentang Deltra untuk sekolah kami.');
const HREF = `https://wa.me/${WHATSAPP_NUMBER}?text=${MESSAGE}`;
---

<style>
  #wa-widget {
    position: fixed;
    bottom: 1.75rem;
    right: 1.75rem;
    z-index: 60;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
  }

  #wa-tooltip {
    background: #0f1c2e;
    color: white;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.5rem 0.9rem;
    border-radius: 0.75rem;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(4px) scale(0.95);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
  }

  #wa-widget:hover #wa-tooltip {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  #wa-btn {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: #25d366;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.45);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
    position: relative;
  }

  #wa-btn:hover {
    transform: scale(1.1) translateY(-2px);
    box-shadow: 0 8px 28px rgba(37, 211, 102, 0.55);
  }

  #wa-btn::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid rgba(37, 211, 102, 0.4);
    animation: wa-pulse 2s ease-out infinite;
  }

  @keyframes wa-pulse {
    0%   { transform: scale(1); opacity: 0.7; }
    70%  { transform: scale(1.35); opacity: 0; }
    100% { transform: scale(1.35); opacity: 0; }
  }
</style>

<div id="wa-widget" aria-label="Chat on WhatsApp">
  <div id="wa-tooltip">Chat with us on WhatsApp</div>
  <a id="wa-btn" href={HREF} target="_blank" rel="noopener noreferrer" aria-label="Open WhatsApp chat">
