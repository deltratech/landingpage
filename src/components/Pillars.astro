---
const pillars = [
  { label: 'Pilar 1', title: 'Smart Administration',  desc: 'Automate schedules, attendance & daily records with AI-powered workflows',          bg: 'bg-mint',     border: '#a8d5c8' },
  { label: 'Pilar 2', title: 'Integrated Learning',   desc: 'Centralize curriculum, assignments & resources in one intelligent system',          bg: 'bg-peach',    border: '#e8b8a8' },
  { label: 'Pilar 3', title: 'Smart Communication',   desc: 'Real-time messaging between teachers, students & parents in one place',             bg: 'bg-lavender', border: '#bbadd8' },
  { label: 'Pilar 4', title: 'AI-Powered Analytics',  desc: 'Data-driven insights and auto-generated reports to support better decisions',        bg: 'bg-sky',      border: '#a5cce0' },
];
---
<section class="bg-surface py-16 px-8 relative overflow-hidden" id="features">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col items-center gap-2.5 text-center mb-10">
      <span class="inline-flex items-center font-mono font-bold text-xs text-primary bg-primary/7 border border-primary/14 rounded-full px-4 py-1.5">
        Core Features
      </span>
      <h2 class="text-primary">4 Pillars of Deltra</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4.5">
      {pillars.map(p => (
        <div class={`${p.bg} border rounded-2xl px-4.5 py-5.5 flex flex-col gap-2.5`} style={`border-color: ${p.border};`}>
          <span class="inline-block self-start font-mono font-bold text-xs text-muted bg-black/6 rounded-md px-2 py-0.5">{p.label}</span>
          <h3 class="text-xl text-primary leading-tight">{p.title}</h3>
          <p class="font-mono text-[13px] text-body leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>

  </div>

  <span class="absolute top-4 left-4.5 text-primary text-sm opacity-15 pointer-events-none">✦</span>
  <span class="absolute top-5.5 right-22 text-primary text-xs opacity-12 pointer-events-none">★</span>
</section>
