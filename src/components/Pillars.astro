---
const pillars = [
  { label: 'Pilar 1', title: 'Core Platform',  desc: 'Automate schedules, attendance & daily records with AI-powered workflows',          bg: 'bg-mint',     border: '#a8d5c8' },
  { label: 'Pilar 2', title: 'Automation',   desc: 'Centralize curriculum, assignments & resources in one intelligent system',          bg: 'bg-peach',    border: '#e8b8a8' },
  { label: 'Pilar 3', title: 'AI Teaching Support',   desc: 'Real-time messaging between teachers, students & parents in one place',             bg: 'bg-lavender', border: '#bbadd8' },
  { label: 'Pilar 4', title: 'Payments & Fees',  desc: 'Data-driven insights and auto-generated reports to support better decisions',        bg: 'bg-sky',      border: '#a5cce0' },
];
---
<section class="bg-surface py-10 md:py-16 px-4 md:px-8 relative overflow-hidden" id="features">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col items-center gap-2.5 text-center mb-10">
      <span class="inline-flex items-center font-sans font-bold text-xs text-primary bg-primary/7 border border-primary/14 rounded-full px-4 py-1.5">
        Core Features
      </span>
      <h2 class="text-primary">4 Pillars of Deltra</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4.5">
      <!-- Pilar 1 -->
      <div class="bg-mint border rounded-2xl px-4.5 py-5.5 flex flex-col gap-2.5" style="border-color: #a8d5c8">
          <span class="inline-block self-start font-sans font-bold text-xs text-muted bg-black/6 rounded-md px-2 py-0.5">Pilar 1</span>
          <h3 class="text-xl text-primary leading-tight">Core Platform</h3>
          <div>
            <p class="font-sans text-[15px] text-body leading-relaxed font-bold">Student Information Management</p>
            <p class="font-sans text-[13px] text-body leading-relaxed">Centralised records, profiles & portfolios</p>
          </div>
          <div>
            <p class="font-sans text-[15px] text-body leading-relaxed font-bold">Attendance Tracking</p>
            <p class="font-sans text-[13px] text-body leading-relaxed">Digital daily attendance capture</p>
          </div>
          <div>
            <p class="font-sans text-[15px] text-body leading-relaxed font-bold">Grade Tracking</p>
            <p class="font-sans text-[13px] text-body leading-relaxed">Performance across subjects & tasks</p>
          </div>
          <div>
            <p class="font-sans text-[15px] text-body leading-relaxed font-bold">Report Card Generation</p>
            <p class="font-sans text-[13px] text-body leading-relaxed">Consistent, streamlined reporting</p>
          </div>
      </div>

      <!-- Pilar 2 -->
      <div class="bg-peach border rounded-2xl px-4.5 py-5.5 flex flex-col gap-2.5" style="border-color: #e8b8a8">
          <span class="inline-block self-start font-sans font-bold text-xs text-muted bg-black/6 rounded-md px-2 py-0.5">Pilar 2</span>
          <h3 class="text-xl text-primary leading-tight">Automation</h3>
          <div>
            <p class="font-sans text-[15px] text-body leading-relaxed font-bold">Contract Automation</p>
            <p class="font-sans text-[13px] text-body leading-relaxed">Teacher & staff contracts from HRIS data</p>
          </div>
          <div>
            <p class="font-sans text-[15px] text-body leading-relaxed font-bold">Parent Feedback Automation</p>
            <p class="font-sans text-[13px] text-body leading-relaxed">Tailored teacher-to-parent updates</p>
          </div>
      </div>

      <!-- Pilar 3 -->
      <div class="bg-lavender border rounded-2xl px-4.5 py-5.5 flex flex-col gap-2.5" style="border-color: #e8b8a8">
          <span class="inline-block self-start font-sans font-bold text-xs text-muted bg-black/6 rounded-md px-2 py-0.5">Pilar 3</span>
          <h3 class="text-xl text-primary leading-tight">AI Teaching Support</h3>
          <div>
            <p class="font-sans text-[15px] text-body leading-relaxed font-bold">AI Teacher Assistant</p>
            <p class="font-sans text-[13px] text-body leading-relaxed">Weekly student KPI summaries</p>
          </div>
          <div>
            <p class="font-sans text-[15px] text-body leading-relaxed font-bold">Teacherpal AI</p>
            <p class="font-sans text-[13px] text-body leading-relaxed">KPI trends & early risk detection</p>
          </div>
          <div>
            <p class="font-sans text-[15px] text-body leading-relaxed font-bold">AI Exam Cruncher</p>
            <p class="font-sans text-[13px] text-body leading-relaxed">Grade- & subject-specific question generation</p>
          </div>
      </div>

      <!-- Pilar 4 -->
      <div class="bg-sky border rounded-2xl px-4.5 py-5.5 flex flex-col gap-2.5" style="border-color: #a5cce0">
          <span class="inline-block self-start font-sans font-bold text-xs text-muted bg-black/6 rounded-md px-2 py-0.5">Pilar 4</span>
          <h3 class="text-xl text-primary leading-tight">Payments & Fees</h3>
          <div>
            <p class="font-sans text-[15px] text-body leading-relaxed font-bold">Invoice Generation</p>
            <p class="font-sans text-[13px] text-body leading-relaxed">Automated tuition & fee billing</p>
          </div>
          <div>
            <p class="font-sans text-[15px] text-body leading-relaxed font-bold">Invoice Distribution</p>
            <p class="font-sans text-[13px] text-body leading-relaxed">WhatsApp & email delivery</p>
          </div>
          <div>
            <p class="font-sans text-[15px] text-body leading-relaxed font-bold">Payment Tracking</p>
            <p class="font-sans text-[13px] text-body leading-relaxed">Real-time status & reconciliation</p>
          </div>
          <div>
            <p class="font-sans text-[15px] text-body leading-relaxed font-bold">Automated Reminders</p>
            <p class="font-sans text-[13px] text-body leading-relaxed">Scheduled overdue follow-ups</p>
          </div>
      </div>
    </div>
  </div>

  <span class="absolute top-4 left-4.5 text-primary text-sm opacity-15 pointer-events-none">✦</span>
  <span class="absolute top-5.5 right-22 text-primary text-xs opacity-12 pointer-events-none">★</span>
</section>
