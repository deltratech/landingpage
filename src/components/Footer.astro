---
const footerCols = [
  { title: 'Product', items: ['Features', 'Pricing', 'Changelog', 'Integrations'] },
  { title: 'Company', items: ['About', 'Careers', 'Press', 'Blog']                },
  { title: 'Support', items: ['Help Center', 'Contact', 'Privacy', 'Terms']       },
];

const socials = [
  { label: 'fb', href: '#', title: 'Facebook'    },
  { label: 'ig', href: '#', title: 'Instagram'   },
  { label: 'tw', href: '#', title: 'Twitter / X' },
  { label: 'li', href: '#', title: 'LinkedIn'    },
];
---
<footer class="bg-primary px-8 pt-12 pb-6">
  <div class="max-w-6xl mx-auto">

    <div class="grid grid-cols-2 md:grid-cols-[2.2fr_1fr_1fr_1fr] gap-8 pb-8 border-b border-white/8">

      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1 flex flex-col gap-3.5">
        <a href="/" aria-label="Deltra home" class="inline-flex">
          <svg width="90" height="28" viewBox="0 0 90 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <text x="0" y="20" font-family="Space Mono, monospace" font-size="16" font-weight="700" fill="#fff">deltra</text>
            <circle cx="80" cy="14" r="5" fill="#1ecfad"/>
          </svg>
        </a>
        <p class="font-mono text-[13px] text-white/40 leading-relaxed max-w-60">
          One platform. Every workflow. Intelligently automated.
        </p>
        <div class="flex gap-2">
          {socials.map(s => (
            <a href={s.href} title={s.title} aria-label={s.title}
               class="w-7.5 h-7.5 rounded-[7px] bg-white/7 border border-white/10 text-white/40 font-mono font-bold text-[10px] uppercase flex items-center justify-center transition-all duration-200 hover:bg-accent hover:text-primary hover:border-accent">
              {s.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Nav columns -->
      {footerCols.map(col => (
        <div class="flex flex-col gap-3">
          <h3 class="font-mono font-bold text-[13px] text-white/60">{col.title}</h3>
          <ul class="flex flex-col gap-2 list-none">
            {col.items.map(item => (
              <li>
                <a href="#" class="font-mono text-[13px] text-white/30 leading-snug transition-colors duration-200 hover:text-accent">
                  {item}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

    </div>

    <div class="pt-5 flex justify-between items-center flex-wrap gap-2 font-mono text-xs text-white/20">
      <span>© 2026 Deltra Inc. All rights reserved.</span>
      <span>Made with ♥ for educators</span>
    </div>

  </div>
</footer>
