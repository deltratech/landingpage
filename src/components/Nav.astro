---
const links = ['Home', 'Features', 'About', 'Contact'];
---
<nav>
  <div class="nav-inner">
    <a href="/" class="logo" aria-label="Deltra home">
      <svg width="100" height="32" viewBox="0 0 100 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <text x="0" y="22" font-family="Space Mono, monospace" font-size="18" font-weight="700" fill="#192B5E">deltra</text>
        <circle cx="90" cy="16" r="5" fill="#2FB5A5"/>
      </svg>
    </a>

    <ul class="nav-links">
      {links.map((link, i) => (
        <li>
          <a
            href={link === 'Home' ? '/' : `#${link.toLowerCase()}`}
            class:list={['nav-link', { active: i === 0 }]}
          >
            {link}
          </a>
        </li>
      ))}
    </ul>

    <a href="#contact" class="btn-demo">Request Demo</a>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #fff;
    border-bottom: 1.5px solid #e8e3da;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    list-style: none;
    align-items: center;
    gap: 28px;
  }

  .nav-link {
    font-size: 15px;
    font-weight: 400;
    color: #666;
    transition: color 0.2s;
  }
  .nav-link:hover { color: #192B5E; }
  .nav-link.active {
    font-weight: 700;
    color: #192B5E;
  }

  .btn-demo {
    background: #192B5E;
    color: #fff;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    font-weight: 700;
    padding: 8px 20px;
    border-radius: 40px;
    white-space: nowrap;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-demo:hover {
    background: #2FB5A5;
    transform: translateY(-1px);
  }
</style>
