---
const links = ['Home', 'Features', 'About', 'Contact'];
---
<nav class="sticky top-0 z-50 bg-white border-b border-border">
  <div class="max-w-6xl mx-auto px-8 py-3.5 flex items-center justify-between gap-6">

    <a href="/" aria-label="Deltra home" class="flex items-center shrink-0">
      <span class="font-mono font-bold text-xl text-primary">deltra</span>
      <span class="w-2.5 h-2.5 rounded-full bg-accent ml-1 mb-2 inline-block"></span>
    </a>

    <ul class="flex items-center gap-7 list-none">
      {links.map((link, i) => (
        <li>
          <a
            href={link === 'Home' ? '/' : `#${link.toLowerCase()}`}
            class={`font-mono text-sm transition-colors duration-200 ${i === 0 ? 'font-bold text-primary' : 'font-normal text-muted hover:text-primary'}`}
          >
            {link}
          </a>
        </li>
      ))}
    </ul>

    <div class="text-white">
      <a
        href="#contact"
        class="font-mono font-bold text-xs bg-primary px-5 py-2 rounded-full whitespace-nowrap transition-all duration-200 hover:bg-accent hover:-translate-y-px"
      >
        Request Demo
      </a> 
    </div>

  </div>
</nav>
