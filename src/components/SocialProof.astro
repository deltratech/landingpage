---
const stats = [
  { number: '500+',    label: 'Schools Onboarded' },
  { number: '10,000+', label: 'Active Teachers'   },
  { number: '95%',     label: 'Satisfaction Rate' },
  { number: '50+',     label: 'Cities Covered'    },
];

const testimonials = [
  {
    name:  'Ms. Sarah Johnson',
    role:  'Teacher, Sunrise Academy',
    quote: '"Deltra saved me hours of admin work every week. I can now focus fully on my students."',
  },
  {
    name:  'Principal David Lee',
    role:  'Principal, Westbrook School',
    quote: '"Our whole school is now on the same page. Communication has never been easier."',
  },
];
---
<section class="bg-primary" id="social-proof">

  <!-- Banner -->
  <div class="relative">
    <div class="w-full h-55 bg-white/4 border-b border-white/7 flex flex-col items-center justify-center gap-3 text-white/30 text-sm text-center">
      <svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="36" cy="26" r="14" fill="#fff" opacity="0.2"/>
        <circle cx="22" cy="30" r="10" fill="#fff" opacity="0.15"/>
        <circle cx="50" cy="30" r="10" fill="#fff" opacity="0.15"/>
        <path d="M4 68c0-17.673 14.327-32 32-32s32 14.327 32 32" fill="#fff" opacity="0.15"/>
      </svg>
      <p>Group photo of students / school community</p>
    </div>

    <!-- Floating trust card -->
    <div class="absolute -bottom-9 right-20 bg-white border border-border rounded-2xl px-5.5 py-4 shadow-[0_8px_28px_rgba(0,0,0,0.14)] z-10 font-mono">
      <p class="font-bold text-[13px] text-primary mb-2">Trusted by 500+ Schools</p>
      <div class="flex items-center mb-2">
        {[0,1,2,3].map(i => (
          <div class={`rounded-full border-2 border-white flex ${i > 0 ? '-ml-2' : ''}`}>
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="14" cy="14" r="14" fill="#ccc"/>
              <circle cx="14" cy="11" r="5" fill="#fff" opacity="0.7"/>
              <path d="M2 26c0-6.627 5.373-12 12-12s12 5.373 12 12" fill="#fff" opacity="0.5"/>
            </svg>
          </div>
        ))}
        <span class="font-mono text-xs text-muted ml-2">+10k users</span>
      </div>
      <div class="flex gap-0.5" aria-label="5 out of 5 stars">
        {[1,2,3,4,5].map(() => <span class="text-accent text-sm">★</span>)}
      </div>
    </div>
  </div>

  <!-- Stats strip -->
  <div class="px-8 pt-15 pb-9">
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-4">
      {stats.map(s => (
        <div class="py-5 px-3 bg-white/5 rounded-xl border border-white/8 flex flex-col items-center gap-1.5 text-center">
          <span class="font-mono font-bold text-[26px] text-accent">{s.number}</span>
          <span class="font-mono text-[13px] text-[#8890b0]">{s.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Testimonials -->
  <div class="px-8 pb-14">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-4">
      {testimonials.map(t => (
        <div class="bg-white/5 rounded-2xl p-5.5 border border-white/9 flex flex-col gap-3">
          <div class="flex gap-3 items-center">
            <div class="w-11 h-11 shrink-0" aria-hidden="true">
              <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="22" cy="22" r="22" fill="#1a2a3a"/>
                <circle cx="22" cy="18" r="8" fill="#fff" opacity="0.5"/>
                <path d="M4 42c0-9.941 8.059-18 18-18s18 8.059 18 18" fill="#fff" opacity="0.35"/>
              </svg>
            </div>
            <div>
              <div class="font-mono font-bold text-[15px] text-white">{t.name}</div>
              <div class="font-mono text-xs text-[#8890b0]">{t.role}</div>
            </div>
          </div>
          <div class="flex gap-0.5" aria-label="5 out of 5 stars">
            {[1,2,3,4,5].map(() => <span class="text-accent text-[13px]">★</span>)}
          </div>
          <p class="font-mono text-sm text-[#b0c8c0] leading-relaxed">{t.quote}</p>
        </div>
      ))}
    </div>
  </div>

</section>
