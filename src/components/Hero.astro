---
const stats = [
  { number: '500+', label: 'Schools' },
  { number: '10k+', label: 'Teachers' },
  { number: '98%', label: 'Satisfaction' },
];
---
<section class="hero" id="home">
  <div class="hero-inner">
    <!-- Left: text content -->
    <div class="hero-text">
      <div class="pill">K-12 Learning Platform</div>
      <h1 class="hero-heading">
        Empowering Schools,<br />Simplifying Teaching
      </h1>
      <p class="hero-sub">
        An LMS that helps teachers focus on students, not administrative tasks
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Request a Demo</a>
        <a href="#features" class="btn btn-outline">Learn More</a>
      </div>
      <div class="hero-stats">
        {stats.map(s => (
          <div class="stat">
            <span class="stat-num">{s.number}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: illustration placeholder -->
    <div class="hero-visual">
      <div class="photo-placeholder">
        <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="32" cy="22" r="14" fill="#b0c4e8" opacity="0.6"/>
          <path d="M4 58c0-15.464 12.536-28 28-28s28 12.536 28 28" fill="#b0c4e8" opacity="0.4"/>
        </svg>
        <p>Teacher / Student<br />Illustration or Photo</p>
      </div>

      <!-- Floating badge: Easy to Use -->
      <div class="badge badge-left">
        <div class="badge-icon badge-icon-teal">✓</div>
        <div>
          <div class="badge-title">Easy to Use</div>
          <div class="badge-sub">No training needed</div>
        </div>
      </div>

      <!-- Floating badge: Active Schools -->
      <div class="badge badge-right">
        <div class="badge-label">Active Schools</div>
        <div class="badge-stat">500+</div>
      </div>
    </div>
  </div>

  <!-- Decorative elements -->
  <span class="deco deco-1">✦</span>
  <span class="deco deco-2">★</span>
  <span class="deco deco-3">✦</span>
  <span class="deco deco-4">○</span>
</section>

<style>
  .hero {
    background: #faf7f2;
    padding: 60px 32px 48px;
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    font-size: 12px;
    font-weight: 700;
    color: #192B5E;
    background: rgba(25, 43, 94, 0.08);
    border: 1px solid rgba(25, 43, 94, 0.15);
    border-radius: 30px;
    padding: 5px 14px;
    align-self: flex-start;
  }

  .hero-heading {
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 700;
    color: #192B5E;
    line-height: 1.15;
  }

  .hero-sub {
    font-size: 16px;
    color: #666;
    line-height: 1.6;
    max-width: 440px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .btn {
    font-family: 'Space Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    padding: 11px 26px;
    border-radius: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.15s, background 0.2s, border-color 0.2s;
    cursor: pointer;
  }
  .btn:hover { transform: translateY(-2px); }

  .btn-primary {
    background: #192B5E;
    color: #fff;
    border: 2px solid #192B5E;
  }
  .btn-primary:hover { background: #2FB5A5; border-color: #2FB5A5; }

  .btn-outline {
    background: transparent;
    color: #192B5E;
    border: 2px solid #192B5E;
  }
  .btn-outline:hover { background: #192B5E; color: #fff; }

  .hero-stats {
    display: flex;
    gap: 28px;
    margin-top: 8px;
    padding-top: 16px;
    border-top: 1px solid #e8e3da;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat-num {
    font-size: 20px;
    font-weight: 700;
    color: #192B5E;
  }

  .stat-label {
    font-size: 12px;
    color: #999;
  }

  /* Right visual */
  .hero-visual {
    position: relative;
  }

  .photo-placeholder {
    width: 100%;
    height: 340px;
    background: #d5d0c8;
    border: 1.5px solid #b0a898;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: #8a8078;
    font-size: 14px;
    text-align: center;
    line-height: 1.5;
  }

  /* Floating badges */
  .badge {
    position: absolute;
    background: #fff;
    border: 1.5px solid #ddd;
    border-radius: 14px;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }

  .badge-left {
    bottom: 24px;
    left: -28px;
  }

  .badge-right {
    top: 24px;
    right: -20px;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }

  .badge-icon {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .badge-icon-teal { background: #d4ede5; color: #2FB5A5; }

  .badge-title {
    font-size: 13px;
    font-weight: 700;
    color: #333;
  }

  .badge-sub {
    font-size: 11px;
    color: #999;
  }

  .badge-label {
    font-size: 11px;
    color: #999;
  }

  .badge-stat {
    font-size: 20px;
    font-weight: 700;
    color: #2FB5A5;
  }

  /* Decorative shapes */
  .deco {
    position: absolute;
    pointer-events: none;
    font-style: normal;
    color: #192B5E;
  }
  .deco-1 { top: 20px; left: 24px; font-size: 14px; opacity: 0.25; }
  .deco-2 { top: 70px; left: 52%; font-size: 12px; opacity: 0.2; }
  .deco-3 { top: 130px; right: 24px; font-size: 10px; opacity: 0.15; }
  .deco-4 { top: 35px; right: 70px; font-size: 30px; opacity: 0.07; }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-visual {
      display: none;
    }
  }
</style>
