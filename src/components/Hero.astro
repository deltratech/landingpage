---
const stats = [
  { number: '500+', label: 'Schools' },
  { number: '10k+', label: 'Teachers' },
  { number: '98%',  label: 'Satisfaction' },
];

const panels = [
  {
    badge: 'K-12 Learning Platform',
    heading: 'One Platform. Every Workflow. Intelligently Automated.',
    body: 'Deltra is your school\'s all-in-one operating system — combining student records, attendance, grading, finance, and AI support in one seamless Indonesian-built platform.',
  },
  {
    badge: 'AI-Powered Insights',
    heading: 'Smarter Teaching Starts With Smarter Data.',
    body: 'Our AI surfaces weekly student KPIs, flags early performance risks, and auto-generates lesson plans and exam questions — so teachers can focus on what truly matters: teaching.',
  },
  {
    badge: 'School Efficiency',
    heading: 'Less Admin. More Time for Students.',
    body: 'Automate invoices, parent communications, staff contracts, and daily schedules. One platform. Zero redundancy. Every workflow handled — so your team stays focused.',
  },
];

const bgImages = [
  'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=1920&q=80',
  'https://images.unsplash.com/photo-1509062522246-3755977927d7?w=1920&q=80',
  'https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=1920&q=80',
  'https://images.unsplash.com/photo-1497633762265-9d179a990aa6?w=1920&q=80',
];
---

<section class="relative h-screen min-h-150 flex items-center justify-center overflow-hidden" id="home">

  <!-- Background slideshow -->
  <div id="bg-slideshow" class="absolute inset-0 z-0">
    {bgImages.map((src, i) => (
      <div
        class="bg-slide absolute inset-0"
        style={`opacity: ${i === 0 ? 1 : 0}; transition: opacity 1s ease-in-out;`}
      >
        <img
          src={src}
          class="w-full h-full object-cover"
          alt=""
          aria-hidden="true"
          loading={i === 0 ? 'eager' : 'lazy'}
        />
      </div>
    ))}
  </div>

  <!-- Dark gradient overlay -->
  <div class="absolute inset-0 z-10 bg-linear-to-b from-black/65 via-black/50 to-black/70 pointer-events-none"></div>

  <!-- Hero content -->
  <div class="relative z-20 w-full max-w-3xl mx-auto px-6 md:px-10 text-center">

    <!-- Badge -->
    <span
      id="hero-badge"
      class="inline-flex self-center font-sans font-semibold text-xs text-white bg-white/15 border border-white/30 rounded-full px-4 py-1.5 mb-5 transition-opacity duration-300"
    >
      {panels[0].badge}
    </span>

    <!-- Text panels -->
    <div id="hero-text-stack" class="relative" style="height: 360px;">
      {panels.map((p, i) => (
        <div
          class={`hero-text-panel absolute inset-x-0 top-0`}
          style={`opacity: ${i === 0 ? 1 : 0}; pointer-events: ${i === 0 ? 'auto' : 'none'}; transition: opacity 0.3s ease-in-out;`}
          data-panel={i}
        >
          <h1
            class={`animation-${i} font-caveat font-bold text-5xl sm:text-6xl md:text-7xl leading-tight text-white mb-4`}
          >
            {p.heading}
          </h1>
          <p class="hero-panel-body font-bold font-sans text-base sm:text-lg text-white/75 leading-relaxed max-w-2xl mx-auto">
            {p.body}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA buttons -->
    <div class="flex gap-4 flex-wrap text-white justify-center mt-10 mb-8">
      <a
        href="#contact"
        data-toast
        class="font-sans font-bold text-sm text-white bg-primary px-8 py-3.5 rounded-full inline-flex items-center gap-2 transition-all duration-200 hover:bg-accent hover:-translate-y-1 hover:shadow-lg hover:shadow-primary/30"
      >
        Request a Demo
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <a
        href="#features"
        class="font-sans font-bold text-sm text-white bg-white/10 border border-white/50 px-8 py-3.5 rounded-full inline-flex items-center gap-2 backdrop-blur-sm transition-all duration-200 hover:bg-white/20 hover:border-white hover:-translate-y-1"
      >
        Learn More
      </a>
    </div>

    <!-- Stats -->
    <div class="flex gap-8 justify-center pt-5 border-t border-white/20">
      {stats.map(s => (
        <div class="flex flex-col gap-0.5 items-center">
          <span class="font-sans font-bold text-5xl text-white">{s.number}</span>
          <span class="font-sans text-xl text-white/60">{s.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Slide indicator dots -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex gap-2">
    {bgImages.map((_, i) => (
      <button
        class="bg-dot w-2.5 h-2.5 rounded-full bg-white transition-opacity duration-300"
        style={`opacity: ${i === 0 ? 1 : 0.35};`}
        data-index={i}
        aria-label={`Slide ${i + 1}`}
      ></button>
    ))}
  </div>

</section>

<script>
  import gsap from 'gsap';
  import Textify from 'textify.js';

  const badgeLabels = ['K-12 Learning Platform', 'AI-Powered Insights', 'School Efficiency'];
  const badgeEl     = document.getElementById('hero-badge')!;
  const bgSlides    = document.querySelectorAll<HTMLElement>('#bg-slideshow .bg-slide');
  const textPanels  = document.querySelectorAll<HTMLElement>('.hero-text-panel');
  const dots        = document.querySelectorAll<HTMLButtonElement>('#home .bg-dot');

  let current = 0;
  let busy    = false;

  // ── Textify instances ──
  const animCfg = (cls: string) => new Textify({
    el: cls,
    animation: {
      customAnimation: true,
      by: 'chars',
      stagger: 0.018,
      duration: 0.22,
      ease: 'expo.inOut',
      animateProps: { opacity: 0, scale: 0 },
    },
  }, gsap);

  const textInstances = [
    animCfg('.animation-0'),
    animCfg('.animation-1'),
    animCfg('.animation-2'),
  ];

  function panelBodyIn(panel: HTMLElement) {
    const body = panel.querySelector<HTMLElement>('.hero-panel-body');
    if (!body) return;
    gsap.killTweensOf(body);
    gsap.to(body, { opacity: 1, y: 0, duration: 0.4, delay: 0.1, ease: 'power2.out' });
  }

  function panelBodyOut(panel: HTMLElement) {
    const body = panel.querySelector<HTMLElement>('.hero-panel-body');
    if (!body) return;
    gsap.killTweensOf(body);
    gsap.to(body, { opacity: 0, y: -6, duration: 0.18, ease: 'power2.in' });
  }

  function resetPanelBody(panel: HTMLElement) {
    const body = panel.querySelector<HTMLElement>('.hero-panel-body');
    if (!body) return;
    gsap.set(body, { opacity: 0, y: 10 });
  }

  function swapBadge(index: number) {
    gsap.to(badgeEl, { opacity: 0, duration: 0.18, onComplete: () => {
      badgeEl.textContent = badgeLabels[index];
      gsap.to(badgeEl, { opacity: 1, duration: 0.22 });
    }});
  }

  function goTo(index: number) {
    if (index === current || busy) return;
    busy = true;
    const prev = current;
    current = index;
    const totalPanels = textPanels.length;

    // Transition background
    bgSlides[prev].style.opacity = '0';
    bgSlides[current % bgSlides.length].style.opacity = '1';

    // Update dots
    dots.forEach((d, i) => { d.style.opacity = i === current % dots.length ? '1' : '0.35'; });

    swapBadge(index % totalPanels);
    panelBodyOut(textPanels[prev % totalPanels]);
    textInstances[prev % totalPanels].animateOut();

    gsap.delayedCall(0.32, () => {
      textPanels[prev % totalPanels].style.opacity = '0';
      textPanels[prev % totalPanels].style.pointerEvents = 'none';

      const nextPanel = textPanels[current % totalPanels];
      resetPanelBody(nextPanel);
      nextPanel.style.pointerEvents = 'auto';

      gsap.fromTo(nextPanel,
        { opacity: 0 },
        { opacity: 1, duration: 0.25, onComplete: () => {
          textInstances[current % totalPanels].animateIn();
          panelBodyIn(nextPanel);
          busy = false;
        }}
      );
    });
  }

  let slideIndex = 0;
  let paused = false;

  function nextSlide() {
    if (!paused) {
      goTo((slideIndex + 1) % Math.max(bgSlides.length, textPanels.length));
      slideIndex = current;
    }
  }

  const timer = setInterval(nextSlide, 5000);

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      goTo(i);
    });
  });

  // Pause on hover
  const section = document.getElementById('home')!;
  section.addEventListener('mouseenter', () => { paused = true; });
  section.addEventListener('mouseleave', () => { paused = false; });

  window.addEventListener('DOMContentLoaded', () => {
    resetPanelBody(textPanels[0] as HTMLElement);
    textInstances[0].animateIn();
    panelBodyIn(textPanels[0] as HTMLElement);
  });
</script>
