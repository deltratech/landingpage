---
import dashboardImg from '../assets/images/one-dashboard.png';

const stats = [
  { number: '500+', label: 'Schools' },
  { number: '10k+', label: 'Teachers' },
  { number: '98%',  label: 'Satisfaction' },
];

const panels = [
  {
    badge: 'K-12 Learning Platform',
    heading: 'One Platform.\nEvery Workflow.\nIntelligently Automated.',
    body: 'Deltra is your school\'s all-in-one operating system — combining student records, attendance, grading, finance, and AI support in one seamless Indonesian-built platform.',
  },
  {
    badge: 'AI-Powered Insights',
    heading: 'Smarter Teaching Starts With Smarter Data.',
    body: 'Our AI surfaces weekly student KPIs, flags early performance risks, and auto-generates lesson plans and exam questions — so teachers can focus on what truly matters: teaching.',
  },
  {
    badge: 'School Efficiency',
    heading: 'Less Admin.\nMore Time for Students.',
    body: 'Automate invoices, parent communications, staff contracts, and daily schedules. One platform. Zero redundancy. Every workflow handled — so your team stays focused.',
  },
];
---

<section class="bg-surface py-10 md:py-16 px-4 md:px-8 relative overflow-hidden" id="home">
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">

    <!-- Left: text panels -->
    <div class="flex flex-col gap-4">

      <!-- Badge (swaps with panel) -->
      <span id="hero-badge" class="inline-flex self-start font-sans font-bold text-xs text-primary bg-primary/7 border border-primary/14 rounded-full px-4 py-1.5 transition-opacity duration-300">
        {panels[0].badge}
      </span>

      <!-- Text stack — all panels absolute, container has fixed height -->
      <div id="hero-text-stack" class="relative" style="height: 400px;">
        {panels.map((p, i) => (
          <div
            class={`hero-text-panel absolute top-0 left-0 w-full ${i > 0 ? 'opacity-0 pointer-events-none' : ''}`}
            data-panel={i}
          >
            <h1
              class={`animation-${i} font-caveat font-bold text-7xl sm:text-7xl md:text-7xl leading-tight text-primary whitespace-pre-line mb-3`}
            >
              {p.heading}
            </h1>
            <p class="hero-panel-body font-sans text-xl text-muted leading-relaxed">
              {p.body}
            </p>
          </div>
        ))}
      </div>

      <!-- CTA buttons (always visible) -->
      <div class="flex gap-3 flex-wrap mt-2 md:mt-4">
        <div class="text-white">
          <a href="#contact" data-toast class="font-sans font-bold text-sm bg-primary px-7 py-3 rounded-full inline-flex items-center transition-all duration-200 hover:bg-[#172840] hover:-translate-y-0.5 hover:scale-[1.03]">
            Request a Demo
          </a>
        </div>
        <div class="text-primary">
          <a href="#features" data-toast class="font-sans font-bold text-sm bg-transparent border-2 border-primary px-7 py-3 rounded-full inline-flex items-center transition-all duration-200 hover:text-white hover:bg-accent hover:-translate-y-0.5 hover:scale-[1.03]">
            Learn More
          </a>
        </div>
      </div>

      <!-- Stats (always visible) -->
      <div class="flex gap-7 mt-2 pt-4 border-t border-border">
        {stats.map(s => (
          <div class="flex flex-col gap-0.5">
            <span class="font-sans font-bold text-xl text-primary">{s.number}</span>
            <span class="font-sans text-xs text-muted">{s.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: visual slideshow -->
    <div class="relative hidden md:block">
      <div id="hero-slideshow" class="relative w-full rounded-2xl overflow-hidden shadow-[0_8px_40px_rgba(0,0,0,0.12)] border border-white/60 bg-white">

        <!-- Slide 1: Dashboard screenshot -->
        <div class="hero-slide absolute inset-0 transition-opacity duration-700 ease-in-out opacity-100">
          <img src={dashboardImg.src} class="w-full h-auto block" alt="Deltra dashboard" />
        </div>

        <!-- Slide 2 -->
        <div class="hero-slide absolute inset-0 transition-opacity duration-700 ease-in-out opacity-0 bg-linear-to-br from-[#eaf4f0] to-[#d5eae4] flex flex-col items-center justify-center gap-3 text-muted text-sm text-center p-8" style="min-height: 240px;">
          <svg width="52" height="52" viewBox="0 0 52 52" fill="none" aria-hidden="true">
            <rect x="6" y="10" width="40" height="36" rx="4" fill="#a8d5c8" opacity="0.5"/>
            <rect x="14" y="4" width="4" height="10" rx="2" fill="#3a9e7f"/>
            <rect x="34" y="4" width="4" height="10" rx="2" fill="#3a9e7f"/>
            <rect x="14" y="24" width="6" height="6" rx="1" fill="#3a9e7f" opacity="0.7"/>
            <rect x="23" y="24" width="6" height="6" rx="1" fill="#3a9e7f" opacity="0.7"/>
            <rect x="32" y="24" width="6" height="6" rx="1" fill="#3a9e7f" opacity="0.4"/>
          </svg>
          <p class="font-sans font-bold text-primary text-base">AI Insights Dashboard</p>
          <p class="font-sans text-xs text-muted">Real-time KPI summaries, risk flags and performance trends — all generated automatically every week.</p>
        </div>

        <!-- Slide 3 -->
        <div class="hero-slide absolute inset-0 transition-opacity duration-700 ease-in-out opacity-0 bg-linear-to-br from-[#eef2fb] to-[#dce6f7] flex flex-col items-center justify-center gap-3 text-muted text-sm text-center p-8" style="min-height: 240px;">
          <svg width="52" height="52" viewBox="0 0 52 52" fill="none" aria-hidden="true">
            <circle cx="26" cy="22" r="13" fill="#b0c4e8" opacity="0.6"/>
            <circle cx="26" cy="22" r="6" fill="#5b7fc4" opacity="0.5"/>
            <path d="M10 44c0-8.837 7.163-16 16-16s16 7.163 16 16" fill="#b0c4e8" opacity="0.4"/>
            <circle cx="38" cy="12" r="5" fill="#5b7fc4" opacity="0.7"/>
            <path d="M35.5 12h5M38 9.5v5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <p class="font-sans font-bold text-primary text-base">Automated Admin Hub</p>
          <p class="font-sans text-xs text-muted">Invoices, contracts, attendance reports and parent messages — handled automatically so your staff can breathe.</p>
        </div>

        <!-- Invisible sizer -->
        <div class="invisible pointer-events-none">
          <img src={dashboardImg.src} class="w-full h-auto block" alt="" aria-hidden="true" />
        </div>

        <!-- Dot indicators -->
        <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5 z-10">
          <button class="hero-dot w-2 h-2 rounded-full bg-primary transition-opacity duration-300 opacity-100" data-index="0" aria-label="Slide 1"></button>
          <button class="hero-dot w-2 h-2 rounded-full bg-primary transition-opacity duration-300 opacity-30"  data-index="1" aria-label="Slide 2"></button>
          <button class="hero-dot w-2 h-2 rounded-full bg-primary transition-opacity duration-300 opacity-30"  data-index="2" aria-label="Slide 3"></button>
        </div>
      </div>

      <!-- Badges -->
      <div class="absolute -bottom-6 -left-7 bg-white border border-border rounded-xl px-4 py-2.5 flex items-center gap-2.5 shadow-md z-20">
        <div class="w-8 h-8 rounded-full bg-tint text-accent flex items-center justify-center text-sm font-bold shrink-0">✓</div>
        <div>
          <div class="font-sans font-bold text-xs text-primary">Easy to Use</div>
          <div class="font-sans text-xs text-muted">No training needed</div>
        </div>
      </div>
      <div class="absolute -top-5 -right-4 bg-white border border-border rounded-xl px-4 py-2.5 shadow-md flex flex-col gap-0.5 z-20">
        <div class="font-sans text-xs text-muted">Active Schools</div>
        <div class="font-sans font-bold text-lg text-accent">500+</div>
      </div>
    </div>

  </div>
</section>

<style>
  /* Textify required — scoped to avoid the page-wide transform:translateZ(0) bug */
  .textify .word,
  .textify .char { display: inline-block; will-change: transform, opacity; }
  .textify .char { position: relative; }
  .textify .char::before, .textify .char::after { content: attr(data-char); position: absolute; top: 0; left: 0; visibility: hidden; display: none; }
  .textify .word::before, .textify .word::after  { content: attr(data-word); position: absolute; top: 0; left: 0; visibility: hidden; display: none; }
  .textify .line-box, .textify .line { overflow: hidden; }
</style>

<script>
  import gsap from 'gsap';
  import Textify from 'textify.js'
  
  const badgeLabels = ['K-12 Learning Platform', 'AI-Powered Insights', 'School Efficiency'];
  const badgeEl = document.getElementById('hero-badge')!;

  // ── Textify instances (customAnimation:true = no auto IntersectionObserver trigger) ──
  const animCfg = (cls: string) => new Textify({
    el: cls,
    animation: {
      customAnimation: true,
      by: 'chars',
      stagger: 0.022,
      duration: 0.25,
      ease: 'expo.inOut',
      animateProps: { opacity: 0, scale: 0 },
    },
  }, gsap);

  const textInstances = [
    animCfg('.animation-0'),
    animCfg('.animation-1'),
    animCfg('.animation-2'),
  ];

  const textPanels   = document.querySelectorAll<HTMLElement>('.hero-text-panel');
  const slides       = document.querySelectorAll<HTMLElement>('#hero-slideshow .hero-slide');
  const dots         = document.querySelectorAll<HTMLElement>('#hero-slideshow .hero-dot');

  let current = 0;
  let busy    = false;
  let timer: ReturnType<typeof setInterval>;

  // ── Animate panel body separately with GSAP ──
  function panelBodyIn(panel: HTMLElement) {
    const body = panel.querySelector<HTMLElement>('.hero-panel-body');
    if (!body) return;
    gsap.fromTo(body, { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.5, delay: 0.3, ease: 'power2.out' });
  }

  function panelBodyOut(panel: HTMLElement) {
    const body = panel.querySelector<HTMLElement>('.hero-panel-body');
    if (!body) return;
    gsap.to(body, { opacity: 0, duration: 0.2, ease: 'power2.in' });
  }

  // ── Swap badge label ──
  function swapBadge(index: number) {
    gsap.to(badgeEl, { opacity: 0, duration: 0.18, onComplete: () => {
      badgeEl.textContent = badgeLabels[index];
      gsap.to(badgeEl, { opacity: 1, duration: 0.22 });
    }});
  }

  // ── Core transition ──
  function goTo(index: number) {
    if (index === current || busy) return;
    busy = true;
    const prev = current;
    current = index;

    // slide out right image
    slides[prev].style.opacity = '0';
    slides[prev].style.pointerEvents = 'none';
    dots[prev].style.opacity = '0.3';

    // slide in new image
    slides[current].style.opacity = '1';
    slides[current].style.pointerEvents = 'auto';
    dots[current].style.opacity = '1';

    // swap badge
    swapBadge(index);

    // animate OUT: heading chars + body
    textInstances[prev].animateOut();
    panelBodyOut(textPanels[prev]);

    // after out delay, swap panel visibility and animate IN
    gsap.delayedCall(0.35, () => {
      // hide prev panel
      textPanels[prev].style.opacity = '0';
      textPanels[prev].style.pointerEvents = 'none';

      // show next panel
      const nextPanel = textPanels[current];
      nextPanel.style.pointerEvents = 'auto';
      gsap.fromTo(nextPanel, { opacity: 0 }, { opacity: 1, duration: 0.25, onComplete: () => {
        // animate IN: heading chars
        textInstances[current].animateIn();
        panelBodyIn(nextPanel);
        busy = false;
      }});
    });
  }

  function next() { goTo((current + 1) % slides.length); }

  function startTimer() { timer = setInterval(next, 4000); }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      goTo(i);
      startTimer();
    });
  });

  // ── Initial animate-in on load ──
  window.addEventListener('DOMContentLoaded', () => {
    textInstances[0].animateIn();
    panelBodyIn(textPanels[0] as HTMLElement);
    startTimer();
  });
</script>
