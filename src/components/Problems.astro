---
const pains = [
  { title: 'Too Much Admin Work',       desc: 'Hours lost daily on paperwork, scheduling & manual tracking',       bg: 'bg-peach',   border: '#e8b8a8' },
  { title: 'Inefficient Communication', desc: 'Messages scattered across WhatsApp, email & phone calls',           bg: 'bg-lavender', border: '#bbadd8' },
  { title: 'No Learning Visibility',    desc: 'No easy way to track student progress or generate insights',        bg: 'bg-sky',     border: '#a5cce0' },
];

const IndonesiaProblem = [
  { score: '~40%', desc: "of a teacher's week lost to admin and reporting" },
  { score: '3+',   desc: 'disconnected tools per school (spreadsheet, chat, paper)' },
  { score: '0',    desc: 'localised AI tools for the Indonesian curriculum' },
  { score: 'Rp',   desc: 'Insufficient resources allocated to development and integration of modern tech' },
];
---
<section class="bg-surface py-10 md:py-16 px-4 md:px-8 relative overflow-hidden" id="problems">
  <div class="max-w-6xl mx-auto">

    <div class="flex flex-col items-center gap-2.5 text-center mb-10">
      <span class="inline-flex items-center font-mono font-bold text-xs text-primary bg-primary/7 border border-primary/14 rounded-full px-4 py-1.5">
        Common Pain Points
      </span>
      <h2 class="text-primary">Sound Familiar?</h2>
      <p class="font-mono text-[15px] text-muted">What schools struggle with every day</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
      {pains.map(p => (
        <div class={`${p.bg} border rounded-2xl px-6 py-7 flex flex-col items-center text-center gap-3`} style={`border-color: ${p.border};`}>
          <h3 class="text-xl text-primary">{p.title}</h3>
          <p class="font-mono text-[13px] text-body leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
    <div class="flex flex-col items-center gap-2.5 text-center mb-10">
      <span class="inline-flex items-center font-mono font-bold text-xs text-primary bg-primary/7 border border-primary/14 rounded-full px-4 py-1.5">
        The Reality in Indonesia
      </span>
      <h2 class="text-primary">Not Just a Pain — A Systemic Problem</h2>
      <p class="font-mono text-[15px] text-muted">
        Across Indonesian schools, these challenges aren’t occasional — they’re the norm.
      </p>

    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-8">
      <div>
        <h1 class="text-2xl md:text-4xl">Most K–12 schools still use spreadsheets, WhatsApp groups and manual report cards draining teacher time and slowing the move to modern tools.</h1>
      </div>
      <div class="grid grid-cols-2 gap-5">
        {IndonesiaProblem.map(p => (
          <div class="bg-green-100 border border-[#a5cce0] rounded-2xl px-6 py-7 flex flex-col items-center text-center gap-3">
            <h3 class="text-xl text-primary">{p.score}</h3>
            <p class="font-mono text-[13px] text-body leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
