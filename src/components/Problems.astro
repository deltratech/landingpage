---
const pains = [
  {
    title: 'Administrative Overload',
    stat: '40%',
    statLabel: 'of teacher time lost to admin each week',
    desc: 'Attendance registers, grade books, parent reports, exam schedules — all manual, all time-consuming, all pulling teachers away from students.',
    color: 'bg-peach',
    border: '#e8b8a8',
    accent: '#c05a3a',
  },
  {
    title: 'Inefficient Communication',
    stat: '3+',
    statLabel: 'separate tools used per school on average',
    desc: 'Critical messages live across WhatsApp groups, email inboxes, and paper notices. Things fall through the cracks. Parents feel left out. Staff feel overwhelmed.',
    color: 'bg-lavender',
    border: '#bbadd8',
    accent: '#7a5aa8',
  },
  {
    title: 'No Learning Visibility',
    stat: '0',
    statLabel: 'localized AI tools for Indonesian K-12 curriculum',
    stat2: 'Rp',
    statLabel2: 'insufficient resources allocated to modern tech integration',
    desc: 'Teachers can\'t see which students are falling behind until it\'s too late — and schools lack the budget and tools to fix it. No AI, no early warning, no data layer.',
    color: 'bg-sky',
    border: '#a5cce0',
    accent: '#2a6a8a',
  },
];
---

<section class="bg-white py-20 md:py-28 relative overflow-hidden" id="problems">
  <!-- Decorative element -->
  <div class="absolute -left-32 top-1/2 -translate-y-1/2 w-80 h-80 rounded-full bg-surface opacity-60 blur-3xl pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-4 md:px-8">

    <div class="text-center mb-14" data-reveal>
      <span class="inline-flex items-center font-sans font-semibold text-xs text-red-500 bg-red-50 border border-red-100 rounded-full px-4 py-1.5 mb-4">
        The Problem
      </span>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-primary mb-4">
        Indonesian Schools Are Running on Systems<br class="hidden md:block"/> Built for a Different Era
      </h2>
      <p class="font-sans text-muted text-lg font-semibold max-w-4xl mx-auto">
        Most K-12 schools still rely on spreadsheets, WhatsApp groups, and paper-based workflows — draining teacher time and slowing down every decision.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-12">
      {pains.map((p, i) => (
        <div
          class={`${(p as any).stat2 ? 'sm:col-span-2' : ''} ${p.color} border rounded-3xl p-7 flex flex-col gap-4 group hover:shadow-md transition-shadow duration-300`}
          style={`border-color: ${p.border};`}
          data-reveal
          data-delay={String((i % 2) + 1)}
        >
          <h3 class="font-display font-bold text-xl text-primary">{p.title}</h3>

          {(p as any).stat2 ? (
            <!-- Dual-stat — one box, divided -->
            <div class="bg-white/50 rounded-2xl flex overflow-hidden">
              <div class="flex-1 px-5 py-4 flex flex-col gap-1">
                <span class="font-display font-bold text-5xl py-2" style={`color: ${p.accent};`}>{p.stat}</span>
                <span class="font-sans text-xs font-semibold uppercase tracking-wider leading-snug" style={`color: ${p.accent};`}>{p.statLabel}</span>
              </div>
              <div class="w-px self-stretch" style={`background: ${p.border};`}></div>
              <div class="flex-1 px-5 py-4 flex flex-col gap-1">
                <span class="font-display font-bold text-5xl py-2" style={`color: ${p.accent};`}>{(p as any).stat2}</span>
                <span class="font-sans text-xs font-semibold uppercase tracking-wider leading-snug" style={`color: ${p.accent};`}>{(p as any).statLabel2}</span>
              </div>
            </div>
          ) : (
            <!-- Single-stat layout -->
            <div class="flex items-start justify-between gap-4">
              <p class="font-sans text-xs font-semibold uppercase tracking-wider" style={`color: ${p.accent};`}>{p.statLabel}</p>
              <span class="font-display font-bold text-5xl shrink-0" style={`color: ${p.accent};`}>{p.stat}</span>
            </div>
          )}

          <p class="font-sans text-body text-sm leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>

    <!-- Transition bridge -->
    <div class="bg-primary rounded-3xl px-8 py-10 text-center" data-reveal>
      <p class="font-display font-bold text-2xl md:text-3xl text-white mb-3">
        Deltra changes all of this.
      </p>
      <p class="font-sans text-white/60 text-base max-w-xl mx-auto mb-6">
        One platform that eliminates fragmentation, automates routine work, and gives school leaders the real-time visibility they need to lead effectively.
      </p>
      <a href="#features" class="font-sans font-bold text-sm text-primary bg-accent px-7 py-3 rounded-full inline-flex items-center gap-2 transition-all duration-200 hover:bg-[#18b899] hover:-translate-y-0.5">
        See How It Works
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>

  </div>
</section>

<style>
  .typed-cursor {
    color: var(--color-accent);
    font-weight: 300;
    animation: typed-blink 0.7s step-end infinite;
  }
  @keyframes typed-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>
