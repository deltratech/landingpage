---
<section class="cta">
  <div class="cta-inner">
    <div class="pill">Get Started Today</div>
    <h2 class="cta-heading">
      Start Transforming<br />Your School Today
    </h2>
    <p class="cta-sub">Join 500+ schools already using Deltra</p>
    <div class="cta-actions">
      <a href="#contact" class="btn-dark">Request a Demo</a>
      <a href="#features" class="btn-ghost">Learn More</a>
    </div>
  </div>

  <span class="deco deco-1">✦</span>
  <span class="deco deco-2">★</span>
  <span class="deco deco-3">○</span>
  <span class="deco deco-4">○</span>
</section>

<style>
  .cta {
    background: var(--color-accent);
    padding: 72px 32px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-inner {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    position: relative;
    z-index: 1;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    font-size: 12px;
    font-weight: 700;
    color: var(--color-primary);
    background: rgba(15, 28, 46, 0.12);
    border: 1px solid rgba(15, 28, 46, 0.2);
    border-radius: 30px;
    padding: 5px 14px;
    font-family: 'Space Mono', monospace;
  }

  .cta-heading {
    font-size: clamp(28px, 4vw, 38px);
    color: var(--color-primary);
    line-height: 1.15;
  }

  .cta-sub {
    font-size: 16px;
    color: rgba(15, 28, 46, 0.7);
  }

  .cta-actions {
    display: flex;
    gap: 14px;
    margin-top: 4px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-dark {
    font-family: 'Space Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    background: var(--color-primary);
    padding: 12px 28px;
    border-radius: 40px;
    display: inline-flex;
    align-items: center;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-dark:hover { background: #172840; transform: translateY(-2px); }

  .btn-ghost {
    font-family: 'Space Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    color: var(--color-primary);
    background: rgba(15, 28, 46, 0.1);
    border: 2px solid rgba(15, 28, 46, 0.25);
    padding: 10px 26px;
    border-radius: 40px;
    display: inline-flex;
    align-items: center;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-ghost:hover { background: rgba(15, 28, 46, 0.18); transform: translateY(-2px); }

  /* Decorative */
  .deco {
    position: absolute;
    pointer-events: none;
    color: rgba(15, 28, 46, 0.12);
  }
  .deco-1 { top: 18px; left: 36px; font-size: 18px; }
  .deco-2 { top: 24px; right: 56px; font-size: 16px; }
  .deco-3 { top: -16px; right: -16px; font-size: 100px; opacity: 0.08; }
  .deco-4 { bottom: -28px; left: -28px; font-size: 110px; opacity: 0.08; }
</style>
