---
---
<section class="bg-accent py-18 px-8 text-center relative overflow-hidden" id="cta">

  <div class="max-w-170 mx-auto flex flex-col items-center gap-4 relative z-10">
    <span class="inline-flex items-center font-mono font-bold text-xs text-primary bg-primary/12 border border-primary/20 rounded-full px-4 py-1.5">
      Get Started Today
    </span>
    <h2 class="text-primary leading-tight text-[clamp(28px,4vw,38px)]">
      Start Transforming<br />Your School Today
    </h2>
    <p class="font-mono text-base text-primary/70">Join 500+ schools already using Deltra</p>
    <div class="flex gap-3.5 mt-1 flex-wrap justify-center">
      <a href="#contact" class="font-mono font-bold text-sm text-white bg-primary px-7 py-3 rounded-full inline-flex items-center transition-all duration-200 hover:bg-[#172840] hover:-translate-y-0.5">
        Request a Demo
      </a>
      <a href="#features" class="font-mono font-bold text-sm text-primary bg-primary/10 border-2 border-primary/25 px-6.5 py-2.5 rounded-full inline-flex items-center transition-all duration-200 hover:bg-primary/18 hover:-translate-y-0.5">
        Learn More
      </a>
    </div>
  </div>

  <span class="absolute top-4.5 left-9 text-primary/12 text-[18px] pointer-events-none">✦</span>
  <span class="absolute top-6 right-14 text-primary/12 text-[16px] pointer-events-none">★</span>
  <span class="absolute -top-4 -right-4 text-primary/8 text-[100px] leading-none pointer-events-none">○</span>
  <span class="absolute -bottom-7 -left-7 text-primary/8 text-[110px] leading-none pointer-events-none">○</span>

</section>
