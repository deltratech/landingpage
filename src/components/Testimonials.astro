---
const testimonials = [
  {
    quote: "Before Deltra, I spent nearly 2 hours every Monday just compiling attendance and grade data. Now it's automatic. I finally have time to actually prepare better lessons.",
    name: 'Ibu Rahmawati Sari',
    role: 'Mathematics Teacher',
    school: 'SMA Negeri 5 Bandung',
    initials: 'RS',
    color: 'bg-mint',
    stars: 5,
  },
  {
    quote: "The AI report feature is extraordinary. What used to take our team a week now takes 20 minutes. Parent satisfaction scores went up 34% in our first semester with Deltra.",
    name: 'Bapak Hendra Gunawan',
    role: 'School Principal',
    school: 'SMP Al-Azhar Bekasi',
    initials: 'HG',
    color: 'bg-lavender',
    stars: 5,
  },
  {
    quote: "We manage 4 campuses under our foundation. Deltra is the first platform that gave us a single, accurate view of operations across all of them. It is built for how Indonesian schools actually work.",
    name: 'Bapak Agus Widodo',
    role: 'Foundation Director',
    school: 'Yayasan Pendidikan Nusantara',
    initials: 'AW',
    color: 'bg-honey',
    stars: 5,
  },
];
---

<section class="bg-surface py-20 md:py-28" id="testimonials">
  <div class="max-w-6xl mx-auto px-4 md:px-8">

    <div class="text-center mb-14" data-reveal>
      <span class="inline-flex items-center font-sans font-semibold text-xs text-accent bg-accent/10 border border-accent/20 rounded-full px-4 py-1.5 mb-4">
        School Stories
      </span>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-primary mb-4">
        Educators Love What Happens Next
      </h2>
      <p class="font-sans text-muted text-lg max-w-xl mx-auto">
        From classroom teachers to foundation directors — here's what schools say after switching to Deltra.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <div
          class="bg-white border border-border rounded-3xl p-7 flex flex-col gap-5 hover:shadow-lg transition-shadow duration-300"
          data-reveal
          data-delay={String(i + 1)}
        >
          <!-- Stars -->
          <div class="flex gap-1">
            {Array.from({ length: t.stars }).map(() => (
              <svg class="w-4 h-4 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="font-sans text-body text-base leading-relaxed flex-1">
            "{t.quote}"
          </blockquote>

          <!-- Attribution -->
          <div class="flex items-center gap-3 pt-4 border-t border-border">
            <div class={`w-10 h-10 rounded-full ${t.color} flex items-center justify-center font-sans font-bold text-sm text-primary shrink-0`}>
              {t.initials}
            </div>
            <div>
              <p class="font-sans font-semibold text-sm text-primary">{t.name}</p>
              <p class="font-sans text-xs text-muted">{t.role} · {t.school}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust strip -->
    <div class="mt-12 bg-white border border-border rounded-2xl py-6 px-8 flex flex-wrap gap-8 justify-center items-center" data-reveal>
      {[
        ['500+', 'Schools using Deltra'],
        ['98%', 'Satisfaction rate'],
        ['4.9/5', 'Average rating'],
        ['<2 wks', 'Average onboarding time'],
      ].map(([val, label]) => (
        <div class="flex flex-col items-center text-center">
          <span class="font-display font-bold text-2xl text-primary">{val}</span>
          <span class="font-sans text-xs text-muted mt-0.5">{label}</span>
        </div>
      ))}
    </div>

  </div>
</section>
