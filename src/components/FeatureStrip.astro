---
import settingsIcon      from 'iconoir/icons/regular/settings.svg?raw';
import openBookIcon      from 'iconoir/icons/regular/open-book.svg?raw';
import brainIcon         from 'iconoir/icons/regular/brain-electricity.svg?raw';
import chatIcon          from 'iconoir/icons/regular/chat-bubble.svg?raw';
import statsIcon         from 'iconoir/icons/regular/stats-up-square.svg?raw';
import creditCardIcon    from 'iconoir/icons/regular/credit-card.svg?raw';
import groupIcon         from 'iconoir/icons/regular/group.svg?raw';
import clipboardIcon     from 'iconoir/icons/regular/clipboard-check.svg?raw';

const features = [
  { label: 'Smart Administration', icon: settingsIcon },
  { label: 'Integrated Learning',  icon: openBookIcon },
  { label: 'AI-Powered Insights',  icon: brainIcon },
  { label: 'Communication Tools',  icon: chatIcon },
  { label: 'Performance Analytics',icon: statsIcon },
  { label: 'Digital Payments',     icon: creditCardIcon },
  { label: 'Student Management',   icon: groupIcon },
  { label: 'Attendance Tracking',  icon: clipboardIcon },
];
---
<div class="bg-primary border-t-4 border-accent px-4 md:px-8 py-6 md:py-7">
  <div class="max-w-6xl mx-auto flex flex-wrap gap-3 justify-center">
    {features.map(f => (
      <div class="flex flex-col items-center gap-2 px-4 py-4 bg-white/5 border border-white/10 border-t-2 border-t-accent rounded-xl min-w-30 flex-1 basis-30 max-w-37 transition-all duration-200 hover:bg-accent/10 hover:-translate-y-0.5 cursor-default">
        <span class="text-accent w-6 h-6 flex items-center justify-center [&>svg]:w-6 [&>svg]:h-6 [&>svg]:stroke-current" set:html={f.icon} />
        <span class="font-mono text-[11px] text-tint/80 text-center leading-snug">{f.label}</span>
      </div>
    ))}
  </div>
</div>
