---
const contactInfo = [
  { icon: '📧', value: 'hello@deltra.io'        },
  { icon: '📞', value: '+62 (800) 123-4567'     },
  { icon: '📍', value: 'Jakarta, Indonesia'      },
];
---
<section class="bg-surface py-16 px-8" id="contact">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">

      <!-- Left: info -->
      <div class="flex flex-col gap-4">
        <span class="inline-flex self-start items-center font-mono font-bold text-xs text-primary bg-primary/7 border border-primary/14 rounded-full px-4 py-1.5">
          Contact Us
        </span>
        <h2 class="text-primary leading-tight">Get in Touch</h2>
        <p class="font-mono text-sm text-body leading-relaxed">
          Ready to see Deltra in action? Fill in the form and our team will reach out within 24 hours.
        </p>
        <div class="flex flex-col gap-3 mt-1">
          {contactInfo.map(c => (
            <div class="flex gap-3 items-center">
              <div class="w-9.5 h-9.5 rounded-full bg-tint border border-border flex items-center justify-center text-base shrink-0" aria-hidden="true">{c.icon}</div>
              <span class="font-mono text-sm text-body">{c.value}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: form -->
      <div class="bg-white rounded-2xl p-7 border border-border">
        <form class="flex flex-col gap-3.5" novalidate>
          <div class="grid grid-cols-2 gap-3">
            <div class="flex flex-col gap-1.5">
              <label for="fullName" class="font-mono font-bold text-xs text-body">Full Name *</label>
              <input id="fullName" type="text" class="font-mono text-[13px] text-body bg-surface border border-border rounded-[10px] px-3.5 py-2.5 outline-none transition-all duration-200 placeholder:text-muted/60 focus:border-accent focus:shadow-[0_0_0_3px_rgba(30,207,173,0.15)]" placeholder="Name..." autocomplete="name" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="schoolName" class="font-mono font-bold text-xs text-body">School Name *</label>
              <input id="schoolName" type="text" class="font-mono text-[13px] text-body bg-surface border border-border rounded-[10px] px-3.5 py-2.5 outline-none transition-all duration-200 placeholder:text-muted/60 focus:border-accent focus:shadow-[0_0_0_3px_rgba(30,207,173,0.15)]" placeholder="School..." autocomplete="organization" />
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="email" class="font-mono font-bold text-xs text-body">Email Address *</label>
            <input id="email" type="email" class="font-mono text-[13px] text-body bg-surface border border-border rounded-[10px] px-3.5 py-2.5 outline-none transition-all duration-200 placeholder:text-muted/60 focus:border-accent focus:shadow-[0_0_0_3px_rgba(30,207,173,0.15)]" placeholder="email@school.edu" autocomplete="email" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="phone" class="font-mono font-bold text-xs text-body">
              Phone <span class="font-normal text-muted">(optional)</span>
            </label>
            <input id="phone" type="tel" class="font-mono text-[13px] text-body bg-surface border border-border rounded-[10px] px-3.5 py-2.5 outline-none transition-all duration-200 placeholder:text-muted/60 focus:border-accent focus:shadow-[0_0_0_3px_rgba(30,207,173,0.15)]" placeholder="+62 (___) ___-____" autocomplete="tel" />
          </div>
          <button type="submit" class="font-mono font-bold text-[15px] text-white bg-primary border-none rounded-xl py-3.5 cursor-pointer mt-1 transition-all duration-200 hover:bg-accent hover:-translate-y-px">
            Submit Request →
          </button>
        </form>
      </div>

    </div>
  </div>
</section>
