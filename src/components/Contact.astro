---
const contactDetails = [
  {
    label: 'Email us',
    value: 'hello@deltratech.id',
    sub: 'We reply within 24 hours',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  },
  {
    label: 'Call or WhatsApp',
    value: '+62 812-3456-7890',
    sub: 'Mon–Fri 08:00–17:00 WIB',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>`,
  },
  {
    label: 'Visit us',
    value: 'Jakarta, Indonesia',
    sub: 'By appointment only',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
];

const roles = ['Kepala Sekolah / Principal', 'Wakil Kepala Sekolah', 'Administrator / TU', 'Guru / Teacher', 'IT / Technology Lead', 'Yayasan / Foundation', 'Other'];
const sizes = [
  { label: '< 200 students',         value: 'below_200' },
  { label: '200–500 students',        value: 'between_200_500' },
  { label: '500–1,000 students',      value: 'between_500_1000' },
  { label: '1,000–2,000 students',    value: 'between_1000_2000' },
  { label: '2,000+ students',         value: 'above_2000' },
];
---

<section class="bg-surface py-20 md:py-28" id="contact">
  <div class="max-w-6xl mx-auto px-4 md:px-8">

    <div class="text-center mb-14" data-reveal>
      <span class="inline-flex items-center font-sans font-semibold text-xs text-accent bg-accent/10 border border-accent/20 rounded-full px-4 py-1.5 mb-4">
        Book a Demo
      </span>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-primary mb-4">
        Let's Talk About Your School
      </h2>
      <p class="font-sans text-muted text-lg max-w-xl mx-auto">
        Fill in the form below and our education team will reach out within 24 hours to schedule your free, personalized demo.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-10 items-start">

      <!-- Left: contact info + trust signals -->
      <div class="flex flex-col gap-6" data-reveal>

        <div class="flex flex-col gap-4">
          {contactDetails.map(c => (
            <div class="flex items-start gap-4 p-4 bg-white border border-border rounded-2xl">
              <div class="w-10 h-10 rounded-xl bg-tint border border-border flex items-center justify-center text-accent shrink-0">
                <span set:html={c.icon}></span>
              </div>
              <div>
                <p class="font-sans font-semibold text-xs text-muted uppercase tracking-wider mb-0.5">{c.label}</p>
                <p class="font-sans font-bold text-sm text-primary">{c.value}</p>
                <p class="font-sans text-xs text-muted">{c.sub}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- WhatsApp CTA -->
        <a
          href="https://wa.me/6281234567890?text=Halo%2C%20saya%20ingin%20demo%20Deltra"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 bg-[#25d366] text-white font-sans font-bold text-sm px-5 py-3.5 rounded-2xl transition-all duration-200 hover:bg-[#1eba57] hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[#25d366]/30"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="white">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.117.551 4.103 1.513 5.83L.057 23.186a.75.75 0 00.914.914l5.356-1.456A11.934 11.934 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.717 9.717 0 01-4.964-1.36l-.355-.213-3.688 1.002 1.001-3.657-.232-.375A9.751 9.751 0 012.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
          </svg>
          Chat via WhatsApp
        </a>

        <!-- Trust signals -->
       

      </div>

      <!-- Right: demo request form -->
      <div class="bg-white border border-border rounded-3xl p-8 shadow-sm" data-reveal data-delay="2">
        <h3 class="font-display font-bold text-xl text-primary mb-6">Request Your Free Demo</h3>

        <form id="demo-form" class="flex flex-col gap-4" novalidate>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label for="contactName" class="font-sans font-semibold text-xs text-body">Your Name *</label>
              <input id="contactName" type="text" required
                class="font-sans text-sm text-body bg-surface border border-border rounded-xl px-4 py-3 outline-none transition-all duration-200 placeholder:text-muted/50 focus:border-accent focus:shadow-[0_0_0_3px_rgba(30,207,173,0.15)]"
                placeholder="Bapak / Ibu ..." autocomplete="name" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="schoolName" class="font-sans font-semibold text-xs text-body">School / Institution Name *</label>
              <input id="schoolName" type="text" required
                class="font-sans text-sm text-body bg-surface border border-border rounded-xl px-4 py-3 outline-none transition-all duration-200 placeholder:text-muted/50 focus:border-accent focus:shadow-[0_0_0_3px_rgba(30,207,173,0.15)]"
                placeholder="SMA / SMP / SD ..." autocomplete="organization" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label for="role" class="font-sans font-semibold text-xs text-body">Your Role *</label>
              <select id="role" required
                class="font-sans text-sm text-body bg-surface border border-border rounded-xl px-4 py-3 outline-none transition-all duration-200 focus:border-accent focus:shadow-[0_0_0_3px_rgba(30,207,173,0.15)] appearance-none cursor-pointer">
                <option value="" disabled selected>Select your role</option>
                {roles.map(r => <option value={r}>{r}</option>)}
              </select>
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="schoolSize" class="font-sans font-semibold text-xs text-body">Number of Students *</label>
              <select id="schoolSize" required
                class="font-sans text-sm text-body bg-surface border border-border rounded-xl px-4 py-3 outline-none transition-all duration-200 focus:border-accent focus:shadow-[0_0_0_3px_rgba(30,207,173,0.15)] appearance-none cursor-pointer">
                <option value="" disabled selected>Select school size</option>
                {sizes.map(s => <option value={s.value}>{s.label}</option>)}
              </select>
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="contactEmail" class="font-sans font-semibold text-xs text-body">School Email *</label>
            <input id="contactEmail" type="email" required
              class="font-sans text-sm text-body bg-surface border border-border rounded-xl px-4 py-3 outline-none transition-all duration-200 placeholder:text-muted/50 focus:border-accent focus:shadow-[0_0_0_3px_rgba(30,207,173,0.15)]"
              placeholder="admin@sekolah.sch.id" autocomplete="email" />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="whatsapp" class="font-sans font-semibold text-xs text-body">
              WhatsApp Number *
            </label>
            <input id="whatsapp" type="tel" required
              class="font-sans text-sm text-body bg-surface border border-border rounded-xl px-4 py-3 outline-none transition-all duration-200 placeholder:text-muted/50 focus:border-accent focus:shadow-[0_0_0_3px_rgba(30,207,173,0.15)]"
              placeholder="+62 8xx-xxxx-xxxx" autocomplete="tel" />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="message" class="font-sans font-semibold text-xs text-body">
              What's your biggest school operations challenge?
              <span class="font-normal text-muted">(optional)</span>
            </label>
            <textarea id="message" rows="3"
              class="font-sans text-sm text-body bg-surface border border-border rounded-xl px-4 py-3 outline-none transition-all duration-200 placeholder:text-muted/50 focus:border-accent focus:shadow-[0_0_0_3px_rgba(30,207,173,0.15)] resize-none"
              placeholder="e.g. we struggle with attendance tracking and parent communication..."></textarea>
          </div>

          <button
            id="demo-submit"
            type="submit"
            class="font-sans font-bold text-sm text-white bg-primary px-6 py-4 rounded-xl cursor-pointer transition-all duration-200 hover:bg-[#172840] hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary/20 mt-1 disabled:opacity-60 disabled:cursor-not-allowed"
          >
            Request Free Demo →
          </button>

          <div id="demo-status" class="hidden text-sm text-center font-sans rounded-xl px-4 py-3"></div>

          <p class="font-sans text-xs text-muted text-center">
            By submitting, you agree to our
            <a href="#" class="text-accent hover:underline">Privacy Policy</a>. We'll never share your data.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>

<script>
  const form   = document.getElementById('demo-form') as HTMLFormElement;
  const btn    = document.getElementById('demo-submit') as HTMLButtonElement;
  const status = document.getElementById('demo-status') as HTMLDivElement;

  function showStatus(msg: string, ok: boolean) {
    status.textContent = msg;
    status.className = `text-sm text-center font-sans rounded-xl px-4 py-3 ${
      ok ? 'bg-accent/10 text-accent border border-accent/20' : 'bg-red-50 text-red-600 border border-red-200'
    }`;
    status.classList.remove('hidden');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name             = (document.getElementById('contactName') as HTMLInputElement).value.trim();
    const schoolName       = (document.getElementById('schoolName') as HTMLInputElement).value.trim();
    const schoolRole       = (document.getElementById('role') as HTMLSelectElement).value;
    const numberOfStudents = (document.getElementById('schoolSize') as HTMLSelectElement).value;
    const email            = (document.getElementById('contactEmail') as HTMLInputElement).value.trim();
    const phone            = (document.getElementById('whatsapp') as HTMLInputElement).value.trim();
    const message          = (document.getElementById('message') as HTMLTextAreaElement).value.trim();

    if (!name || !email || !schoolName || !schoolRole || !numberOfStudents || !phone) {
      showStatus('Please fill in all required fields.', false);
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Sending…';
    status.classList.add('hidden');

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, phone, message, schoolName, schoolRole, numberOfStudents }),
      });

      const data = await res.json();

      if (res.ok && data.success) {
        showStatus('Thanks! Our team will reach out within 24 hours.', true);
        form.reset();
      } else {
        showStatus(data.message ?? 'Something went wrong. Please try again.', false);
      }
    } catch {
      showStatus('Unable to send. Please try WhatsApp or email us directly.', false);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Request Free Demo →';
    }
  });
</script>
