---
const contactInfo = [
  { icon: '📧', value: 'hello@deltra.io' },
  { icon: '📞', value: '+62 (800) 123-4567' },
  { icon: '📍', value: 'Jakarta, Indonesia' },
];
---
<section class="contact" id="contact">
  <div class="section-inner">
    <div class="contact-grid">
      <!-- Left: info -->
      <div class="contact-info">
        <div class="pill">Contact Us</div>
        <h2 class="contact-heading">Get in Touch</h2>
        <p class="contact-desc">
          Ready to see Deltra in action? Fill in the form and our team will reach out within 24 hours.
        </p>
        <div class="contact-details">
          {contactInfo.map(c => (
            <div class="contact-item">
              <div class="contact-icon-wrap" aria-hidden="true">{c.icon}</div>
              <span class="contact-value">{c.value}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: form -->
      <div class="contact-form-wrap">
        <form class="contact-form" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="fullName" class="form-label">Full Name *</label>
              <input id="fullName" type="text" class="form-input" placeholder="Name..." autocomplete="name" />
            </div>
            <div class="form-group">
              <label for="schoolName" class="form-label">School Name *</label>
              <input id="schoolName" type="text" class="form-input" placeholder="School..." autocomplete="organization" />
            </div>
          </div>
          <div class="form-group">
            <label for="email" class="form-label">Email Address *</label>
            <input id="email" type="email" class="form-input" placeholder="email@school.edu" autocomplete="email" />
          </div>
          <div class="form-group">
            <label for="phone" class="form-label">Phone <span class="optional">(optional)</span></label>
            <input id="phone" type="tel" class="form-input" placeholder="+62 (___) ___-____" autocomplete="tel" />
          </div>
          <button type="submit" class="btn-submit">Submit Request →</button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: #faf7f2;
    padding: 64px 32px;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  /* Left info */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    font-size: 12px;
    font-weight: 700;
    color: #192B5E;
    background: rgba(25, 43, 94, 0.08);
    border: 1px solid rgba(25, 43, 94, 0.15);
    border-radius: 30px;
    padding: 5px 14px;
    align-self: flex-start;
  }

  .contact-heading {
    font-size: 28px;
    font-weight: 700;
    color: #192B5E;
    line-height: 1.2;
  }

  .contact-desc {
    font-size: 14px;
    color: #666;
    line-height: 1.7;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 4px;
  }

  .contact-item {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .contact-icon-wrap {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #f5edc8;
    border: 1.5px solid rgba(0,0,0,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }

  .contact-value {
    font-size: 14px;
    color: #555;
  }

  /* Right form */
  .contact-form-wrap {
    background: #fff;
    border-radius: 20px;
    padding: 28px;
    border: 1.5px solid #e8e3da;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-label {
    font-size: 12px;
    font-weight: 700;
    color: #444;
    font-family: 'Space Mono', monospace;
  }

  .optional {
    font-weight: 400;
    color: #999;
  }

  .form-input {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: #333;
    background: #faf7f2;
    border: 1.5px solid #e0dbd2;
    border-radius: 10px;
    padding: 10px 14px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .form-input::placeholder { color: #bbb; }
  .form-input:focus {
    border-color: #2FB5A5;
    box-shadow: 0 0 0 3px rgba(47,181,165,0.12);
  }

  .btn-submit {
    font-family: 'Space Mono', monospace;
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    background: #192B5E;
    border: none;
    border-radius: 12px;
    padding: 13px;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    margin-top: 4px;
  }
  .btn-submit:hover {
    background: #2FB5A5;
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
